<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TrackFinder</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TrackFinder.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
</head>
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var hasPortalSidebar = currentController == "Community";
}
<body class="@(hasPortalSidebar ? "has-portal-sidebar" : null)" style="padding:0;margin:0">
    <header class="tf-topbar" >
        <div class=" align-items-center" style=" display:grid; grid-template-columns :1fr auto; width:100%">
            <div style="justify-self:start">
                  <a class="tf-brand" asp-area="" asp-controller="Home" asp-action="Index"><img src="~/image/logo.jpg" alt="Logo" class="brand-logo">Track Finder</a>

            </div>
            <div style="justify-self:end">

            @if (hasPortalSidebar)
            {
                <button type="button" class="tf-hamburger" id="portalSidebarToggle" aria-label="Toggle navigation menu" aria-expanded="false" >
                    <span class="fa-solid fa-bars"></span>
                </button>
            }
            </div>
        </div>
        <div>
            <nav class="tf-nav" aria-label="Main navigation">
                <a asp-area="" asp-controller="Home" asp-action="Index">Courses</a>
                <a class="@(currentController == "Community" ? "active" : null)" asp-area="" asp-controller="Community" asp-action="Index">Community</a>
                <a href="#">Assessments</a>
            </nav>
        </div>
        @functions
        {
            private static string Initials(string? firstName, string? lastName)
            {
                var first = string.IsNullOrWhiteSpace(firstName) ? "C" : firstName.Trim()[0].ToString();
                var last = string.IsNullOrWhiteSpace(lastName) ? string.Empty : lastName.Trim()[0].ToString();
                return (first + last).ToUpperInvariant();
            }
        }
        <div class="tf-icons" aria-label="Account tools">
            <a class="tf-icon-btn" href="#" aria-label="Notifications"><span class="fa-solid fa-bell"></span></a>
            <a class="tf-icon-btn" href="#" aria-label="Settings"><span class="fa-solid fa-gear"></span></a>
    <a class="tf-icon-btn tf-icon-btn--avatar" href="#" aria-label="Account"><span class="tf-profile">@Initials("Current", "User")</span></a>
        </div>
    </header>

    @if (hasPortalSidebar)
    {
        <div class="tf-sidebar-overlay" id="portalSidebarOverlay"></div>
    }

    <main class="tf-shell" role="main">
        @RenderBody()
    </main>
    <footer style="text-align:center">
        <div style=" margin-top:28px;padding:22px 0;border-top:1px solid #d8e2ef;color:#5c6b7d;font-size:.9rem;text-align:center">copyright-TrackFinder©2026</div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
