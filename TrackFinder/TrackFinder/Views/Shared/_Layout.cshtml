<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TrackFinder</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
            * {
                font-family: 'Segoe UI', sans-serif;
            }

            body {
                background: #f0f4f8;
                color: #2c3e50;
            }

            /* Navbar */
            .navbar-main {
                background: white;
                border-bottom: 1px solid #e5e9f0;
                padding: 12px 32px;
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                z-index: 1000;
                display: flex;
                align-items: center;
                justify-content: space-between;
                height: 62px;
            }

            .navbar-logo {
                display: flex;
                align-items: center;
                gap: 10px;
                text-decoration: none;
            }

                .navbar-logo span {
                    font-weight: 700;
                    font-size: 1.1rem;
                    color: #1a3a5c;
                    letter-spacing: -0.3px;
                }

            .navbar-links {
                display: flex;
                align-items: center;
                gap: 28px;
            }

                .navbar-links a {
                    text-decoration: none;
                    color: #555;
                    font-size: 0.92rem;
                    font-weight: 500;
                    padding-bottom: 4px;
                }

                    .navbar-links a:hover,
                    .navbar-links a.active {
                        color: #1a3a5c;
                        border-bottom: 2px solid #2a7fa5;
                    }

            .navbar-icons {
                display: flex;
                align-items: center;
                gap: 18px;
            }

                .navbar-icons i {
                    font-size: 1.2rem;
                    color: #666;
                    cursor: pointer;
                }

                    .navbar-icons i:hover {
                        color: #1a3a5c;
                    }

            .user-avatar {
                width: 36px;
                height: 36px;
                border-radius: 50%;
                background: #1a3a5c;
                color: white;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 700;
                font-size: 0.82rem;
                cursor: pointer;
            }

            /* Sidebar */
            .sidebar {
                position: fixed;
                top: 62px;
                left: 0;
                width: 215px;
                height: calc(100vh - 62px);
                background: white;
                border-right: 1px solid #e5e9f0;
                padding: 16px 0;
            }

                .sidebar a {
                    display: flex;
                    align-items: center;
                    gap: 10px;
                    padding: 10px 22px;
                    text-decoration: none;
                    color: #555;
                    font-size: 0.88rem;
                    font-weight: 500;
                    transition: all 0.15s;
                }

                    .sidebar a:hover {
                        background: #f5f7fa;
                        color: #1a3a5c;
                    }

                    .sidebar a.active {
                        background: #f0f4f8;
                        color: #1a3a5c;
                        font-weight: 600;
                        border-right: 3px solid #2a7fa5;
                    }

                    .sidebar a i {
                        font-size: 1rem;
                        width: 18px;
                    }

            /* Main Content */
            .main-content {
                margin-left: 215px;
                margin-top: 62px;
                padding: 28px 32px;
                min-height: calc(100vh - 62px);
            }

            /* Typography */
            h5, h6 {
                color: #1a3a5c;
            }

            .text-muted {
                color: #7a8fa6 !important;
            }

            /* Cards */
            .card {
                border: none !important;
                box-shadow: 0 2px 12px rgba(0,0,0,0.06) !important;
            }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar-main">
        <a class="navbar-logo" asp-controller="Home" asp-action="Index">
            <!-- تم استبدال الأيقونة القديمة بصورة اللوجو المودرن الجديد بتاعك وموزون بالملي -->
            <img src="~/images/track-logo.png" alt="Track Finder Logo" style="width: 32px; height: 32px; border-radius: 6px; object-fit: cover;" />
            <span>Track Finder</span>
        </a>
        <div class="navbar-links">
            <a href="#">Courses</a>
            <a href="#">Community</a>
            <a href="#">Assessments</a>
        </div>
        <div class="navbar-icons">
            <i class="bi bi-bell"></i>
            <i class="bi bi-gear"></i>
            <div class="user-avatar">TF</div>
        </div>
    </nav>

    <!-- Sidebar -->
    <div class="sidebar">
        <a href="#">
            <i class="bi bi-grid-1x2"></i> Dashboard
        </a>
        <a href="#">
            <i class="bi bi-play-circle"></i> Courses
        </a>
        <a href="#">
            <i class="bi bi-people"></i> Community
        </a>
        <a href="#">
            <i class="bi bi-clipboard-check"></i> Assessments
        </a>
        <a asp-controller="Achievement" asp-action="Index" class="active">
            <i class="bi bi-trophy"></i> Achievements
        </a>
        <a href="#">
            <i class="bi bi-person"></i> Profile
        </a>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
