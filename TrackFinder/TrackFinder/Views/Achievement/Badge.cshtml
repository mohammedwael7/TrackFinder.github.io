@model TrackFinder.Models.ViewModels.AchievementViewModel
@{
    ViewData["Title"] = "Badges Guide";
}

<div style="background-color: #f8fafc; padding: 3rem 2rem; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; min-height: 100vh; position: relative;">

    <!-- زرار العودة للصفحة الرئيسية (تمت إضافته بشياكة فوق على الشمال) -->
    <div style="max-width: 1200px; margin: 0 auto 1.5rem auto; text-align: left;">
        <a asp-action="Index" style="color: #2a7fa5; font-size: 0.88rem; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 0.25rem;">
            <i class="bi bi-arrow-left-short" style="font-size: 1.2rem;"></i> Back to Achievements
        </a>
    </div>

    <!-- Header الموسطن الشيك -->
    <div style="text-align: center; margin-bottom: 3rem;">
        <h4 style="color: #1a3a5c; font-weight: 800; margin: 0; font-size: 1.8rem; letter-spacing: 0.5px;">Mastery Badges Guide</h4>
        <p style="color: #7a8fa6; font-size: 0.95rem; margin: 0; margin-top: 0.5rem; max-width: 600px; margin-left: auto; margin-right: auto;">
            Explore all available digital insignia and learn the specific requirements to unlock them on your journey.
        </p>
    </div>

    <!-- Container الكروت المربعة المتناسقة -->
    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 2rem; max-width: 1200px; margin: 0 auto;">

        @foreach (var badge in Model.AllBadges)
        {
            // فحص هل الطالب الحالي كسب البادج دي ولا لسه عشان تنور
            var earned = Model.EarnedBadges.Any(eb => eb.BadgeId == badge.BadgeId);

            <div style="width: 260px; background: #ffffff; border-radius: 16px; padding: 2rem 1.5rem; text-align: center; box-shadow: 0 4px 20px rgba(0,0,0,0.02); border: 1.5px solid @(earned ? "#2c5282" : "#e2e8f0"); position: relative; transition: transform 0.2s; box-sizing: border-box;">

                <!-- أيقونة البادج الدائرية المنورة أو الرمادية -->
                <div style="width: 86px; height: 86px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem auto; position: relative; background-color: @(earned ? "#e0f2fe" : "#f1f5f9"); border: 2.5px solid @(earned ? "#2c5282" : "#94a3b8"); box-shadow: @(earned ? "0 4px 15px rgba(44,82,130,0.15)" : "none");">
                    <i class="@(badge.BadgeIconClass ?? "bi bi-patch-check")" style="font-size: 2rem; color: @(earned ? "#2c5282" : "#94a3b8");"></i>

                    @if (badge.Level > 1)
                    {
                        <span style="position: absolute; top: -2px; right: -2px; background: #3a8fc4; color: white; border-radius: 20px; font-size: 0.6rem; font-weight: 700; padding: 2px 7px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">LVL @badge.Level</span>
                    }
                </div>

                <!-- اسم البادج -->
                <h6 style="color: #1a3a5c; font-weight: 700; margin: 0 0 0.5rem 0; font-size: 1.1rem;">@badge.BadgeName</h6>

                <!-- وصف البادج -->
                <p style="color: #7a8fa6; font-size: 0.83rem; margin: 0 0 1.5rem 0; line-height: 1.4; min-height: 40px;">
                    @badge.BadgeDescription
                </p>

                <!-- خط فاصل رفيع -->
                <div style="height: 1px; background-color: #f0f4f8; margin-bottom: 1rem;"></div>

                <!-- شرط الحصول عليها (المطلوب بالملي) -->
                <div>
                    <span style="display: block; color: #2a7fa5; font-weight: 700; font-size: 0.68rem; letter-spacing: 0.5px; margin-bottom: 0.25rem;">HOW TO EARN</span>
                    <p style="color: #1a3a5c; font-weight: 600; font-size: 0.83rem; margin: 0; line-height: 1.3;">
                        @badge.UnlockCondition
                    </p>
                </div>

                <!-- شريط الحالة التفاعلي (مكتملة / مقفلة) -->
                <div style="position: absolute; top: 12px; right: 12px;">
                    @if (earned)
                    {
                        <span style="background: #dcfce7; color: #15803d; padding: 2px 8px; border-radius: 12px; font-size: 0.65rem; font-weight: 700;">Unlocked</span>
                    }
                    else
                    {
                        <span style="background: #f1f5f9; color: #64748b; padding: 2px 8px; border-radius: 12px; font-size: 0.65rem; font-weight: 700;">Locked</span>
                    }
                </div>

            </div>
        }

    </div>
</div>

