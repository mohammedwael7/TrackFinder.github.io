@model TrackFinder.Models.AchievementModels.Badges
@{
    ViewData["Title"] = "Add Badge";
}

<!-- وسم خارجي مرن ومستقل يضمن التوسط في السنتر بالملي ورأسياً وأفقياً -->
<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%; padding: 2rem 0; background-color: #f8fafc; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; box-sizing: border-box;">

    <!-- تحديد عرض ثابت وملموم للعنوان والكارت لضمان المظهر المربع -->
    <div style="width: 100%; max-width: 500px; padding: 0 15px; box-sizing: border-box;">

        <!-- Header -->
        <div style="margin-bottom: 1.5rem; text-align: left;">
            <h5 style="color: #1a3a5c; font-weight: 700; margin: 0 0 0.25rem 0; font-size: 1.35rem;">Add New Badge</h5>
            <p style="color: #7a8fa6; font-size: 0.85rem; margin: 0;">Create a unique digital insignia to reward milestones.</p>
        </div>

        <!-- Form Card المربع المظبوط مع زيادة الطول والـ Padding الرأسي -->
        <div style="background: #ffffff; border-radius: 16px; padding: 2.5rem; box-shadow: 0 4px 24px rgba(0,0,0,0.03); border: none; width: 100%; box-sizing: border-box;">
            <form asp-action="CreateBadge" method="post" style="width: 100%; margin: 0;">

                <!-- Badge Name -->
                <div style="margin-bottom: 1.5rem; width: 100%;">
                    <label style="display: block; color: #1a3a5c; font-weight: 700; font-size: 0.75rem; letter-spacing: 0.5px; margin-bottom: 0.5rem;">BADGE NAME</label>
                    <input asp-for="BadgeName" style="display: block; width: 100%; border-radius: 10px; border: 1.5px solid #dde3ea; font-size: 0.88rem; padding: 0.75rem 1rem; background-color: #fcfdfe; box-sizing: border-box;" placeholder="e.g. Speed Coder" />
                </div>

                <!-- Description -->
                <div style="margin-bottom: 1.5rem; width: 100%;">
                    <label style="display: block; color: #1a3a5c; font-weight: 700; font-size: 0.75rem; letter-spacing: 0.5px; margin-bottom: 0.5rem;">DESCRIPTION</label>
                    <input asp-for="BadgeDescription" style="display: block; width: 100%; border-radius: 10px; border: 1.5px solid #dde3ea; font-size: 0.88rem; padding: 0.75rem 1rem; background-color: #fcfdfe; box-sizing: border-box;" placeholder="Short description explaining the reward..." />
                </div>

                <!-- Level -->
                <div style="margin-bottom: 1.5rem; width: 100%;">
                    <label style="display: block; color: #1a3a5c; font-weight: 700; font-size: 0.75rem; letter-spacing: 0.5px; margin-bottom: 0.5rem;">LEVEL</label>
                    <input asp-for="Level" type="number" style="display: block; width: 100%; border-radius: 10px; border: 1.5px solid #dde3ea; font-size: 0.88rem; padding: 0.75rem 1rem; background-color: #fcfdfe; box-sizing: border-box;" placeholder="1" value="1" />
                </div>

                <!-- Unlock Condition -->
                <div style="margin-bottom: 1.5rem; width: 100%;">
                    <label style="display: block; color: #1a3a5c; font-weight: 700; font-size: 0.75rem; letter-spacing: 0.5px; margin-bottom: 0.5rem;">UNLOCK CONDITION</label>
                    <input asp-for="UnlockCondition" style="display: block; width: 100%; border-radius: 10px; border: 1.5px solid #dde3ea; font-size: 0.88rem; padding: 0.75rem 1rem; background-color: #fcfdfe; box-sizing: border-box;" placeholder="e.g. Top 5% in speed tests" />
                </div>

                <!-- Icon Class -->
                <div style="margin-bottom: 2rem; width: 100%;">
                    <label style="display: block; color: #1a3a5c; font-weight: 700; font-size: 0.75rem; letter-spacing: 0.5px; margin-bottom: 0.5rem;">ICON CLASS (BOOTSTRAP ICONS)</label>
                    <input asp-for="BadgeIconClass" style="display: block; width: 100%; border-radius: 10px; border: 1.5px solid #dde3ea; font-size: 0.88rem; padding: 0.75rem 1rem; background-color: #fcfdfe; box-sizing: border-box;" placeholder="bi bi-lightning" />
                    <small style="color: #7a8fa6; font-size: 0.78rem; display: block; margin-top: 0.5rem;">💡 Hint: Use <code style="color: #2a7fa5; font-family: monospace;">bi bi-patch-check</code> or <code style="color: #2a7fa5; font-family: monospace;">bi bi-lightning</code></small>
                </div>

                <!-- Buttons -->
                <div style="display: flex; gap: 0.75rem; width: 100%;">
                    <button type="submit" style="flex: 1; background: linear-gradient(135deg, #2c5282 0%, #3a8fc4 100%); color: white; border: none; border-radius: 10px; font-weight: 600; padding: 0.8rem; font-size: 0.88rem; cursor: pointer; box-shadow: 0 4px 12px rgba(44,82,130,0.15);">
                        Save Badge
                    </button>
                    <a asp-action="Badges" style="flex: 1; background: #f0f4f8; color: #1a3a5c; border-radius: 10px; font-weight: 600; padding: 0.8rem; font-size: 0.88rem; border: none; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; box-sizing: border-box;">
                        Cancel
                    </a>
                </div>

            </form>
        </div>

    </div>
</div>
