@model TrackFinder.Models.ViewModels.AchievementViewModel
@{
    ViewData["Title"] = "Achievements";
}

<div style="background-color: #f8fafc; padding: 2rem; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; min-height: 100vh;">
    <!-- Top Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h4 style="color: #1a3a5c; font-weight: 700; margin: 0; font-size: 1.5rem;">Achievements</h4>
            <p style="color: #7a8fa6; font-size: 0.88rem; margin: 0; margin-top: 0.25rem;">Track your progress and earned rewards</p>
        </div>
    </div>

    <!-- Section: Verified Certificates -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
        <div>
            <h5 style="color: #1a3a5c; font-weight: 700; margin: 0; font-size: 1.1rem;">Verified Certificates</h5>
            <p style="color: #7a8fa6; font-size: 0.83rem; margin: 0;">Formal recognition of your technical mastery.</p>
        </div>
    </div>

    <!-- Row: Certificates Container -->
    <div style="display: flex; flex-wrap: wrap; gap: 1.5rem; margin-bottom: 3rem;">
        <!-- Featured Certificate -->
        @if (Model.FeaturedCertificate != null)
        {
            <div style="flex: 1; min-width: 350px; background: #ffffff; border-radius: 16px; padding: 1.5rem; box-shadow: 0 4px 20px rgba(0,0,0,0.01); display: flex; gap: 1.5rem;">
                <div style="width: 120px; height: 150px; background: linear-gradient(135deg, #2c5282, #3a8fc4); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; box-shadow: 0 4px 15px rgba(44,82,130,0.15);">
                    <i class="bi bi-award" style="font-size: 2.8rem; color: white;"></i>
                </div>
                <div style="flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between;">
                    <div>
                        <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 0.5rem;">
                            <span style="background: #e0f2fe; color: #0369a1; padding: 4px 12px; border-radius: 20px; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.5px;">FEATURED ACHIEVEMENT</span>
                            <small style="color: #7a8fa6; font-size: 0.78rem;">Issued: @Model.FeaturedCertificate.IssuedAt.ToString("MMM yyyy")</small>
                        </div>
                        <h6 style="color: #1a3a5c; font-weight: 700; margin: 0 0 0.5rem 0; font-size: 1.05rem;">@Model.FeaturedCertificate.Certificate?.Title</h6>
                        <p style="color: #7a8fa6; font-size: 0.83rem; margin: 0; line-height: 1.4;">@Model.FeaturedCertificate.Certificate?.Description</p>
                    </div>
                    <div style="display: flex; gap: 0.75rem; margin-top: 1rem;">
                        <a href="@Model.FeaturedCertificate.Certificate?.CertificateUrl" target="_blank" style="background: #2c5282; color: white; padding: 0.5rem 1.25rem; border-radius: 8px; font-size: 0.83rem; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; box-shadow: 0 4px 10px rgba(44,82,130,0.1);"><i class="bi bi-download"></i> Download PDF</a>
                        <button onclick="copyCertificateLink('@Model.FeaturedCertificate.Certificate?.CertificateUrl')" style="background: #f0f4f8; color: #1a3a5c; padding: 0.5rem 1.25rem; border-radius: 8px; font-size: 0.83rem; font-weight: 600; border: none; display: inline-flex; align-items: center; gap: 0.5rem; cursor: pointer;"><i class="bi bi-share"></i> Share</button>
                    </div>
                </div>
            </div>
        }

        <!-- Regular Certificates Loop -->
        @foreach (var cert in Model.StudentCertificates.Where(c => !c.IsFeatured))
        {
            <div style="width: 280px; background: #ffffff; border-radius: 16px; padding: 1.5rem; box-shadow: 0 4px 20px rgba(0,0,0,0.01); display: flex; flex-direction: column; justify-content: space-between; border: 1px solid #f0f4f8;">
                <div>
                    <div style="width: 42px; height: 42px; background: #2c5282; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; box-shadow: 0 4px 10px rgba(44,82,130,0.1);">
                        <i class="bi bi-file-earmark-text" style="color: white; font-size: 1.1rem;"></i>
                    </div>
                    <h6 style="color: #1a3a5c; font-weight: 700; margin: 0 0 0.5rem 0; font-size: 1rem;">@cert.Certificate?.Title</h6>
                    <p style="color: #7a8fa6; font-size: 0.83rem; margin: 0; line-height: 1.4; margin-bottom: 1.5rem;">@cert.Certificate?.Description</p>
                </div>
                <a href="@cert.Certificate?.CertificateUrl" target="_blank" style="color: #2a7fa5; font-size: 0.83rem; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 0.25rem;">
                    <i class="bi bi-file-earmark"></i> View Certificate
                </a>
            </div>
        }

        <!-- Next Milestone Card -->
        @if (Model.NextMilestoneCertificate != null)
        {
            <a asp-action="MyCertificates" asp-route-studentId="@Model.StudentCertificates.FirstOrDefault()?.StudentId" style="text-decoration: none; color: inherit; display: block;">
                <div style="width: 280px; background: #ffffff; border-radius: 16px; padding: 1.5rem; border: 2px dashed #dde3ea; display: flex; flex-direction: column; justify-content: space-between; box-shadow: none; height: 100%; box-sizing: border-box;">
                    <div>
                        <div style="width: 42px; height: 42px; border: 2px solid #dde3ea; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; color: #2c5282; background-color: #f0f4f8;">
                            <i class="bi bi-plus" style="font-size: 1.4rem; font-weight: bold;"></i>
                        </div>
                        <h6 style="color: #1a3a5c; font-weight: 700; margin: 0 0 0.5rem 0; font-size: 1rem;">Next Milestone</h6>
                        <p style="color: #7a8fa6; font-size: 0.83rem; margin: 0; line-height: 1.4; margin-bottom: 1.5rem;">@Model.NextMilestoneCertificate.UnlockRequirement</p>
                    </div>
                    <div style="margin-top: auto;">
                        <div style="width: 100%; height: 6px; background: #f0f4f8; border-radius: 10px; overflow: hidden;">
                            <div style="width: 60%; height: 100%; background: linear-gradient(90deg, #2c5282, #3a8fc4); border-radius: 10px;"></div>
                        </div>
                    </div>
                </div>
            </a>
        }
    </div>

    <!-- Section: Mastery Badges (تم تعديل التوجيه هنا لـ Badge بالمفرد أوتوماتيك) -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem;">
        <h5 id="badges-section" style="color: #1a3a5c; font-weight: 700; margin: 0; font-size: 1.1rem; scroll-margin-top: 2rem;">Mastery Badges</h5>
        <a asp-action="Badge" style="color: #2a7fa5; font-size: 0.85rem; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 0.25rem;">
            View Badges Guide <i class="bi bi-arrow-right-short" style="font-size: 1.1rem;"></i>
        </a>
    </div>
    <p style="color: #7a8fa6; font-size: 0.83rem; margin: 0; margin-bottom: 1.5rem;">Earn unique digital insignia as you progress through Track Finder.</p>

    <!-- Badges Wrapper Flex -->
    <div style="display: flex; flex-wrap: wrap; gap: 2rem; margin-bottom: 4rem;">
        @foreach (var badge in Model.AllBadges)
        {
            var earned = Model.EarnedBadges.Any(eb => eb.BadgeId == badge.BadgeId);
            <div style="width: 100px; text-align: center;">
                <div style="width: 76px; height: 76px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 0.75rem auto; position: relative; background-color: @(earned ? "#e0f2fe" : "#f1f5f9"); border: 2.5px solid @(earned ? "#2c5282" : "#e2e8f0"); box-shadow: @(earned ? "0 4px 12px rgba(44,82,130,0.12)" : "none");">
                    <i class="@(badge.BadgeIconClass ?? "bi bi-patch-check")" style="font-size: 1.6rem; color: @(earned ? "#2c5282" : "#94a3b8");"></i>
                    @if (badge.Level > 1)
                    {
                        <span style="position: absolute; top: -2px; right: -2px; background: #3a8fc4; color: white; border-radius: 20px; font-size: 0.58rem; font-weight: 700; padding: 2px 6px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">LVL @badge.Level</span>
                    }
                </div>
                <p style="font-weight: 600; margin: 0 0 2px 0; font-size: 0.82rem; color: #1a3a5c;">@badge.BadgeName</p>
                <p style="margin: 0; font-size: 0.68rem; color: #7a8fa6; line-height: 1.2;">@badge.UnlockCondition</p>
            </div>
        }
    </div>

    <!-- Bottom Peak Banner -->
    <div style="background: linear-gradient(135deg, #2c5282 0%, #3a8fc4 100%); border-radius: 16px; padding: 2rem; position: relative; overflow: hidden; box-shadow: 0 10px 25px rgba(44,82,130,0.15);">
        <div style="position: absolute; right: -40px; bottom: -40px; width: 220px; height: 220px; background: rgba(255,255,255,0.06); border-radius: 50%; display: flex; align-items: center; justify-content: center; pointer-events: none;">
            <i class="bi bi-star-fill" style="font-size: 7rem; color: rgba(255,255,255,0.03);"></i>
        </div>
        <h5 style="color: white; font-weight: 700; margin: 0 0 0.5rem 0; font-size: 1.25rem;">Quick Access Profile</h5>
