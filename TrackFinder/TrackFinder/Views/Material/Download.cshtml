@model TrackFinder.Models.CourseModels.Material
@{
    ViewData["Title"] = "Download Material";
}

<link rel="stylesheet" href="~/css/material/style.css" />


<div class="material-container">
    <div class="material-card download-card">
        <h2 class="material-title">Download Material</h2>
        <div class="material-info">
            <p><strong>File Name:</strong> @Model.FileName</p>
            <p><strong>Type:</strong> @Model.ContentType</p>
        </div>

        <form asp-action="Download" asp-controller="Material" method="post" class="material-form">
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="form-actions download-actions">
                <button type="submit" class="btn-primary btn-download">Download File</button>
                <a asp-controller="Lesson" asp-action="Details" asp-route-id="@Model.LessonId" class="btn-secondary">Back to Lesson</a>
            </div>
        </form>
    </div>
</div>
