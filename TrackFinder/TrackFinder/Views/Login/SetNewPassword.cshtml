@model TrackFinder.DTOs.AuthenticationDTOs.SetNewPasswordDto
@{
    ViewData["Title"] = "Set New Password";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    var email = ViewBag.Email as string ?? Model?.Email ?? "";
    var token = ViewBag.Token as string ?? Model?.Token ?? "";
}

<div class="auth-header">
    <img src="~/images/Logo.png" alt="Track Finder Logo" class="auth-logo" />
    <div class="auth-brand">Track Finder</div>
    <div class="auth-tagline">CS Learning Portal</div>
</div>

<div class="auth-card">
    <div style="text-align:center;margin-bottom:8px;">
        <div style="width:56px;height:56px;background:#e5eeff;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;margin-bottom:16px;">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#006191" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
        </div>
        <h1 style="font-size:22px;font-weight:700;color:#0b1c30;margin-bottom:8px;">Set New Password</h1>
        <p style="font-size:14px;color:#3f4850;line-height:1.6;">
            Enter your new password for<br />
            <strong style="color:#006191;">@email</strong>
        </p>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert-error">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            @Html.ValidationSummary(true)
        </div>
    }

    <form asp-action="SetNewPassword" asp-controller="Login" method="post" id="setPasswordForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Email" value="@email" />
        <input type="hidden" asp-for="Token" value="@token" />

        <div class="form-group">
            <label class="form-label" asp-for="NewPassword">New Password</label>
            <div class="input-wrapper">
                <span class="input-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                </span>
                <input asp-for="NewPassword" class="form-input" type="password"
                       id="newPasswordInput" placeholder="••••••••" autocomplete="new-password" />
                <button type="button" class="input-action" id="togglePassword" title="Show/hide password">
                    <svg id="eyeIcon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
            </div>
            <span asp-validation-for="NewPassword" class="field-error"></span>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="ConfirmNewPassword">Confirm New Password</label>
            <div class="input-wrapper">
                <span class="input-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                </span>
                <input asp-for="ConfirmNewPassword" class="form-input" type="password"
                       id="confirmPasswordInput" placeholder="••••••••" autocomplete="new-password" />
            </div>
            <span asp-validation-for="ConfirmNewPassword" class="field-error"></span>
        </div>

        <button type="submit" class="btn-primary" id="resetBtn">Reset Password</button>
    </form>

    <div style="text-align:center;margin-top:20px;">
        <a href="/Login" style="font-size:13px;color:#6f7881;text-decoration:none;">
            ← Back to Sign In
        </a>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('togglePassword').addEventListener('click', function () {
        const input   = document.getElementById('newPasswordInput');
        const eyeIcon = document.getElementById('eyeIcon');
        const isHidden = input.type === 'password';
        input.type = isHidden ? 'text' : 'password';
        eyeIcon.innerHTML = isHidden
            ? '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>'
            : '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
    });

    document.getElementById('setPasswordForm').addEventListener('submit', function () {
        const btn = document.getElementById('resetBtn');
        setTimeout(function () {
            btn.disabled = true;
            btn.textContent = 'Resetting...';
        }, 100);
    });
</script>
}
