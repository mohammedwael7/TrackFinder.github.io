@model TrackFinder.DTOs.AuthenticationDTOs.ForgotPasswordDto
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-header">
    <img src="~/images/Logo.png" alt="Track Finder Logo" class="auth-logo" />
    <div class="auth-brand">Track Finder</div>
    <div class="auth-tagline">CS Learning Portal</div>
</div>

<div class="auth-card">
    <div style="text-align:center;margin-bottom:8px;">
        <div style="width:56px;height:56px;background:#e5eeff;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;margin-bottom:16px;">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#006191" stroke-width="2">
                <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 7L2 7"/>
            </svg>
        </div>
        <h1 style="font-size:22px;font-weight:700;color:#0b1c30;margin-bottom:8px;">Forgot Password?</h1>
        <p style="font-size:14px;color:#3f4850;line-height:1.6;">
            Enter your email address and we'll send you a code to reset your password.
        </p>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-error">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            @TempData["ErrorMessage"]
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert-error">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            @Html.ValidationSummary(true)
        </div>
    }

    <form asp-action="ForgotPassword" asp-controller="Login" method="post" id="forgotPasswordForm">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label class="form-label" asp-for="Email">Email Address</label>
            <div class="input-wrapper">
                <span class="input-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 7L2 7"/></svg>
                </span>
                <input asp-for="Email" class="form-input" type="email"
                       placeholder="name@university.edu" autocomplete="email" />
            </div>
            <span asp-validation-for="Email" class="field-error"></span>
        </div>

        <button type="submit" class="btn-primary" id="sendCodeBtn">Send Reset Code</button>
    </form>

    <div style="text-align:center;margin-top:20px;">
        <a href="/Login" style="font-size:13px;color:#6f7881;text-decoration:none;">
            ← Back to Sign In
        </a>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('forgotPasswordForm').addEventListener('submit', function () {
        const btn = document.getElementById('sendCodeBtn');
        setTimeout(function () {
            btn.disabled = true;
            btn.textContent = 'Sending...';
        }, 100);
    });
</script>
}
