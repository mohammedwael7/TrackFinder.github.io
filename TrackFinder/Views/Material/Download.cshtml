@model TrackFinder.Models.CourseModels.Material
@{
    ViewData["Title"] = "Download Material";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="card" style="max-width:520px;">
    <div class="card-title">Download Material</div>
    <div style="margin-top:16px;display:flex;flex-direction:column;gap:8px;">
        <div><strong style="color:var(--secondary);">File Name:</strong> <span style="color:var(--text-muted)">@Model.FileName</span></div>
        <div><strong style="color:var(--secondary);">Type:</strong> <span style="color:var(--text-muted)">@Model.ContentType</span></div>
    </div>

    <form asp-action="Download" asp-controller="Material" method="post" class="form-actions">
        <input type="hidden" name="id" value="@Model.Id" />
        <button type="submit" class="btn btn-primary">Download File</button>
        <a asp-controller="Lesson" asp-action="Details" asp-route-id="@Model.LessonId" class="btn btn-ghost">Back to Lesson</a>
    </form>
</div>
