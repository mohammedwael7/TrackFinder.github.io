@model TrackFinder.ViewModels.MaterialUploadVM
@{
    ViewData["Title"] = "Upload Material";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="card" style="max-width:520px;">
    <div class="card-title">Upload Material</div>
    <div class="card-subtitle">Only .rar and .zip files are allowed.</div>

    <form asp-action="Create" asp-controller="Material" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="LessonId" />

        <div class="form-group">
            <label asp-for="File">File</label>
            <input asp-for="File" type="file" class="form-control" accept=".rar,.zip" />
            <span asp-validation-for="File" class="field-validation-error"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Upload</button>
            <a asp-controller="Lesson" asp-action="Details" asp-route-id="@Model.LessonId" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
</div>
