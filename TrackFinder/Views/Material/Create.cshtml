@model TrackFinder.ViewModels.MaterialUploadVM
@{
    ViewData["Title"] = "Upload Material";
}

<link rel="stylesheet" href="~/css/material/style.css" />

<div class="material-container">
    <div class="material-card">
        <h2 class="material-title">Upload Material</h2>
        <p class="material-subtitle">Only .rar and .zip files are allowed</p>

        <form asp-action="Create" asp-controller="Material" method="post" enctype="multipart/form-data" class="material-form">
            <input type="hidden" asp-for="LessonId" />

            <div class="form-group">
                <label asp-for="File" class="form-label"></label>
                <input asp-for="File" type="file" class="form-input-file" accept=".rar,.zip" />
                <span asp-validation-for="File" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary">Upload</button>
                <a asp-controller="Lesson" asp-action="Details" asp-route-id="@Model.LessonId" class="btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
