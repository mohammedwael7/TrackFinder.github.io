    <script>
            (function() {
                const tabs = document.querySelectorAll('.screen-tab');
                const panels = document.querySelectorAll('.screen-panel');
                tabs.forEach(tab => {
                    tab.addEventListener('click', () => {
                        tabs.forEach(t => { t.classList.remove('active'); t.style.background='transparent'; t.style.color='#475569'; });
                        tab.classList.add('active');
                        const tabName = tab.getAttribute('data-tab');
                        if(tabName==='student'){ tab.style.background='#e0f0ff'; tab.style.color='#0b2b44'; }
                        else if(tabName==='teacher'){ tab.style.background='#d1fae5'; tab.style.color='#065f46'; }
                        else if(tabName==='security'){ tab.style.background='#fef3c7'; tab.style.color='#92400e'; }
                        else if(tabName==='earnings'){ tab.style.background='#ede9fe'; tab.style.color='#5b21b6'; }
                        else if(tabName==='learning'){ tab.style.background='#fce7f3'; tab.style.color='#9d174d'; }
                        else if(tabName==='achievements'){ tab.style.background='#fff7ed'; tab.style.color='#c2410c'; }
                        panels.forEach(p => p.style.display='none');
                        const panel = document.getElementById('panel-'+tabName);
                        if(panel) panel.style.display='block';
                    });
                });
            })();
    </script>

    <script>
        // ═══════════════ FADE SECTIONS ON SCROLL ═══════════════
        (function() {
            const fadeElements = document.querySelectorAll('.fade-section');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                    }
                });
            }, { threshold: 0.15, rootMargin: "0px 0px -40px 0px" });

            fadeElements.forEach(el => observer.observe(el));

            window.addEventListener('load', () => {
                fadeElements.forEach(el => {
                    const rect = el.getBoundingClientRect();
                    if (rect.top < window.innerHeight - 80) {
                        el.classList.add('visible');
                    }
                });
            });
        })();

        // ═══════════════ TRACK SLIDER ═══════════════
        (function() {
            const slides = document.querySelectorAll('.track-slide');
            const dots = document.querySelectorAll('.track-dot');
            let currentIndex = 0;
            let interval;

            function showSlide(index) {
                slides.forEach(s => s.classList.remove('active'));
                dots.forEach(d => d.classList.remove('active-dot'));
                slides[index].classList.add('active');
                dots[index].classList.add('active-dot');
                currentIndex = index;
            }

            dots.forEach(dot => {
                dot.addEventListener('click', () => {
                    const index = parseInt(dot.getAttribute('data-index'));
                    showSlide(index);
                    resetInterval();
                });
            });

            function nextSlide() {
                const next = (currentIndex + 1) % slides.length;
                showSlide(next);
            }

            function resetInterval() {
                clearInterval(interval);
                interval = setInterval(nextSlide, 4000);
            }

            interval = setInterval(nextSlide, 4000);
        })();

        // ═══════════════ SMOOTH CUBE ROTATION WITH SPEED INTERPOLATION ═══════════════
        (function() {
            const cube = document.getElementById('heroCube');
            const heroVisual = document.getElementById('heroVisual');
            if (!cube || !heroVisual) return;

            const normalSpeed = 20;
            const hoverSpeed = normalSpeed * 0.25;
            let currentSpeed = normalSpeed;
            let targetSpeed = normalSpeed;
            let rotationY = 40;
            const lerpFactor = 0.04;
            let lastTime = performance.now();

            heroVisual.addEventListener('mouseenter', () => {
                targetSpeed = hoverSpeed;
            });

            heroVisual.addEventListener('mouseleave', () => {
                targetSpeed = normalSpeed;
            });

            function animate(now) {
                const dt = Math.min((now - lastTime) / 1000, 0.1);
                lastTime = now;
                currentSpeed += (targetSpeed - currentSpeed) * lerpFactor;
                rotationY += currentSpeed * dt;
                if (rotationY > 10000) rotationY -= 360 * Math.floor(rotationY / 360);
                cube.style.transform = 'rotateX(-25deg) rotateY(' + rotationY + 'deg)';
                requestAnimationFrame(animate);
            }

            requestAnimationFrame(animate);
        })();

        // ═══════════════ LAVA LAMP EGG BLOBS (FIXED SCROLLING) ═══════════════
        (function() {
            const canvas = document.getElementById('lavaCanvas');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            let width, height;
            let mouseX = 0.5,
                mouseY = 0.5;
            let targetMouseX = 0.5,
                targetMouseY = 0.5;

            class EggBlob {
                constructor(index) {
                    this.index = index;
                    this.reset(true);
                }
                reset(initial) {
                    this.x = Math.random() * width;
                    this.y = Math.random() * height;
                    this.baseRadius = 220 + Math.random() * 160;
                    this.radius = this.baseRadius;
                    const colors = [
                        [25, 80, 130], [40, 110, 160], [70, 140, 190], [15, 55, 95],
                        [50, 120, 175], [90, 160, 210], [30, 90, 145], [60, 130, 185],
                        [20, 65, 110], [80, 150, 200]
                    ];
                    this.color = colors[Math.floor(Math.random() * colors.length)];
                    this.alphaBase = 0.25 + Math.random() * 0.4;
                    this.speedX = (Math.random() - 0.5) * 0.5;
                    this.speedY = (Math.random() - 0.5) * 0.5;
                    this.wobbleOffset = Math.random() * Math.PI * 2;
                    this.deformPoints = [];
                    this.targetDeforms = [];
                    for (let i = 0; i < 12; i++) {
                        this.deformPoints.push(1.0);
                        this.targetDeforms.push(1.0);
                    }
                }
                update(allBlobs, mx, my, dt) {
                    dt = dt || 1.0;
                    const targetX = width * mx;
                    const targetY = height * my;
                    const dxMouse = targetX - this.x;
                    const dyMouse = targetY - this.y;
                    const distMouse = Math.sqrt(dxMouse * dxMouse + dyMouse * dyMouse) || 1;
                    const mouseForce = 0.012 * (1 - Math.min(distMouse / 500, 0.85));
                    this.speedX += dxMouse * mouseForce;
                    this.speedY += dyMouse * mouseForce;
                    const SEPARATION_DISTANCE = 420;
                    const ATTRACTION_DISTANCE = 650;
                    for (let other of allBlobs) {
                        if (other === this) continue;
                        const dx = other.x - this.x;
                        const dy = other.y - this.y;
                        const dist = Math.sqrt(dx * dx + dy * dy) || 1;
                        if (dist < SEPARATION_DISTANCE) {
                            const force = (SEPARATION_DISTANCE - dist) / SEPARATION_DISTANCE * 0.09;
                            this.speedX -= (dx / dist) * force;
                            this.speedY -= (dy / dist) * force;
                            const angleToOther = Math.atan2(dy, dx);
                            const deformStrength = (SEPARATION_DISTANCE - dist) / SEPARATION_DISTANCE * 0.4;
                            this.applyDeformation(angleToOther, -deformStrength);
                        } else if (dist < ATTRACTION_DISTANCE) {
                            const force = (dist - SEPARATION_DISTANCE) / (ATTRACTION_DISTANCE - SEPARATION_DISTANCE) * 0.03;
                            this.speedX += (dx / dist) * force;
                            this.speedY += (dy / dist) * force;
                            const angleToOther = Math.atan2(dy, dx);
                            const stretchStrength = (dist - SEPARATION_DISTANCE) / (ATTRACTION_DISTANCE - SEPARATION_DISTANCE) * 0.25;
                            this.applyDeformation(angleToOther, stretchStrength);
                        }
                    }
                    const currentSpeed = Math.sqrt(this.speedX * this.speedX + this.speedY * this.speedY);
                    if (currentSpeed > 0.1) {
                        const moveAngle = Math.atan2(this.speedY, this.speedX);
                        const stretchAmount = Math.min(currentSpeed * 0.08, 0.3);
                        this.applyDeformation(moveAngle + Math.PI, stretchAmount);
                        this.applyDeformation(moveAngle, -stretchAmount * 0.5);
                    }
                    this.speedX += Math.sin(Date.now() * 0.0015 + this.wobbleOffset) * 0.018;
                    this.speedY += Math.cos(Date.now() * 0.0018 + this.wobbleOffset) * 0.018;
                    this.speedY += 0.03;
                    this.speedX *= 0.995;
                    this.speedY *= 0.995;
                    const maxSpeed = 9.5;
                    const speedMag = Math.sqrt(this.speedX * this.speedX + this.speedY * this.speedY);
                    if (speedMag > maxSpeed) {
                        this.speedX = (this.speedX / speedMag) * maxSpeed;
                        this.speedY = (this.speedY / speedMag) * maxSpeed;
                    }
                    this.x += this.speedX * dt;
                    this.y += this.speedY * dt;
                    const margin = this.baseRadius * 0.5;
                    if (this.x < margin) { this.x = margin;
                        this.speedX *= -0.4; }
                    if (this.x > width - margin) { this.x = width - margin;
                        this.speedX *= -0.4; }
                    if (this.y < margin) { this.y = margin;
                        this.speedY *= -0.4; }
                    if (this.y > height - margin) { this.y = height - margin;
                        this.speedY *= -0.4; }
                    for (let i = 0; i < this.deformPoints.length; i++) {
                        this.deformPoints[i] += (this.targetDeforms[i] - this.deformPoints[i]) * 0.08;
                        this.targetDeforms[i] += (1.0 - this.targetDeforms[i]) * 0.03;
                    }
                    this.radius = this.baseRadius + Math.sin(Date.now() * 0.004 + this.wobbleOffset) * 20;
                }
                applyDeformation(angle, strength) {
                    const normalizedAngle = ((angle % (Math.PI * 2)) + Math.PI * 2) % (Math.PI * 2);
                    const pointIndex = Math.round(normalizedAngle / (Math.PI * 2) * this.deformPoints.length) % this.deformPoints.length;
                    for (let i = -1; i <= 1; i++) {
                        const idx = (pointIndex + i + this.deformPoints.length) % this.deformPoints.length;
                        const falloff = i === 0 ? 1.0 : 0.5;
                        this.targetDeforms[idx] += strength * falloff;
                        this.targetDeforms[idx] = Math.max(0.5, Math.min(1.6, this.targetDeforms[idx]));
                    }
                }
                draw(ctx) {
                    const [r, g, b] = this.color;
                    const numPoints = this.deformPoints.length;
                    ctx.beginPath();
                    for (let i = 0; i < numPoints; i++) {
                        const angle = (i / numPoints) * Math.PI * 2 - Math.PI / 2;
                        const deform = this.deformPoints[i];
                        const px = this.x + Math.cos(angle) * this.radius * deform;
                        const py = this.y + Math.sin(angle) * this.radius * deform;
                        if (i === 0) { ctx.moveTo(px, py); } else {
                            const prevAngle = ((i - 1) / numPoints) * Math.PI * 2 - Math.PI / 2;
                            const prevDeform = this.deformPoints[i - 1];
                            const prevPx = this.x + Math.cos(prevAngle) * this.radius * prevDeform;
                            const prevPy = this.y + Math.sin(prevAngle) * this.radius * prevDeform;
                            ctx.quadraticCurveTo((prevPx + px) / 2, (prevPy + py) / 2, px, py);
                        }
                    }
                    ctx.closePath();
                    const gradient = ctx.createRadialGradient(this.x - this.radius * 0.2, this.y - this.radius * 0.25,
                        this.radius * 0.1, this.x, this.y, this.radius * 1.1);
                    gradient.addColorStop(0,
                        'rgba(' + Math.min(255, r + 40) + ',' + Math.min(255, g + 30) + ',' + Math.min(255, b + 20) + ',' + (this.alphaBase + 0.25) + ')');
                    gradient.addColorStop(0.4, 'rgba(' + r + ',' + g + ',' + b + ',' + (this.alphaBase + 0.1) + ')');
                    gradient.addColorStop(0.7,
                        'rgba(' + Math.max(0, r - 20) + ',' + Math.max(0, g - 15) + ',' + Math.max(0, b - 10) + ',' + (this.alphaBase * 0.5) + ')');
                    gradient.addColorStop(1,
                        'rgba(' + Math.max(0, r - 40) + ',' + Math.max(0, g - 30) + ',' + Math.max(0, b - 15) + ',0)');
                    ctx.fillStyle = gradient;
                    ctx.fill();
                    const highlightGrad = ctx.createRadialGradient(this.x - this.radius * 0.25, this.y - this.radius * 0.3,
                        this.radius * 0.05, this.x - this.radius * 0.15, this.y - this.radius * 0.2, this.radius * 0.45);
                    highlightGrad.addColorStop(0, 'rgba(220,235,255,' + (this.alphaBase * 0.5) + ')');
                    highlightGrad.addColorStop(1, 'rgba(180,210,255,0)');
                    ctx.beginPath();
                    for (let i = 0; i < numPoints; i++) {
                        const angle = (i / numPoints) * Math.PI * 2 - Math.PI / 2;
                        const deform = this.deformPoints[i];
                        const px = this.x + Math.cos(angle) * this.radius * deform;
                        const py = this.y + Math.sin(angle) * this.radius * deform;
                        if (i === 0) ctx.moveTo(px, py);
                        else {
                            const prevAngle = ((i - 1) / numPoints) * Math.PI * 2 - Math.PI / 2;
                            const prevDeform = this.deformPoints[i - 1];
                            const prevPx = this.x + Math.cos(prevAngle) * this.radius * prevDeform;
                            const prevPy = this.y + Math.sin(prevAngle) * this.radius * prevDeform;
                            ctx.quadraticCurveTo((prevPx + px) / 2, (prevPy + py) / 2, px, py);
                        }
                    }
                    ctx.closePath();
                    ctx.fillStyle = highlightGrad;
                    ctx.fill();
                }
            }

            const blobs = [];
            const BLOB_COUNT = 8;

            function resizeCanvas() {
                const section = document.querySelector('.antigravity-section');
                if (section) {
                    width = section.clientWidth;
                    height = section.clientHeight;
                } else {
                    width = window.innerWidth;
                    height = window.innerHeight;
                }
                canvas.width = width;
                canvas.height = height;
                blobs.forEach(b => {
                    b.x = Math.min(width, Math.max(0, b.x));
                    b.y = Math.min(height, Math.max(0, b.y));
                });
            }

            function initBlobs() {
                blobs.length = 0;
                for (let i = 0; i < BLOB_COUNT; i++) {
                    blobs.push(new EggBlob(i));
                }
            }

            window.addEventListener('resize', resizeCanvas);
            const section = document.querySelector('.antigravity-section');
            if (section) {
                section.addEventListener('mousemove', (e) => {
                    const rect = section.getBoundingClientRect();
                    targetMouseX = (e.clientX - rect.left) / rect.width;
                    targetMouseY = (e.clientY - rect.top) / rect.height;
                });
                section.addEventListener('mouseleave', () => {
                    targetMouseX = 0.5;
                    targetMouseY = 0.5;
                });
            }

            function updateMouse() {
                mouseX += (targetMouseX - mouseX) * 0.05;
                mouseY += (targetMouseY - mouseY) * 0.05;
            }
            let lastTimeLava = performance.now();

            function animateLava(now) {
                let dt = (now - lastTimeLava) / 16.6;
                if (dt > 3) dt = 3;
                lastTimeLava = now;
                updateMouse();
                ctx.clearRect(0, 0, width, height);
                const bgGrad = ctx.createRadialGradient(width / 2, height / 2, 0, width / 2, height / 2, Math.max(width, height) * 0.7);
                bgGrad.addColorStop(0, '#020810');
                bgGrad.addColorStop(1, '#010308');
                ctx.fillStyle = bgGrad;
                ctx.fillRect(0, 0, width, height);
                for (let b of blobs) { b.update(blobs, mouseX, mouseY, dt); }
                for (let b of blobs) { b.draw(ctx); }
                requestAnimationFrame(animateLava);
            }

            resizeCanvas();
            initBlobs();
            requestAnimationFrame(animateLava);
        })();
    </script>
    <script>
        (function() {
            var toggle = document.getElementById('navToggle');
            var links = document.getElementById('navLinks');
            if (toggle && links) {
                toggle.addEventListener('click', function(e) {
                    e.stopPropagation();
                    links.classList.toggle('open');
                });
                document.addEventListener('click', function(e) {
                    if (!links.contains(e.target) && e.target !== toggle) {
                        links.classList.remove('open');
                    }
                });
            }
        })();
    </script>
