@model TrackDetailsVM
@{
    ViewData["Title"] = "Track Details";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .td-hero {
        background: linear-gradient(135deg, var(--secondary) 0%, var(--primary-dark) 100%);
        border-radius: var(--radius-lg);
        padding: 32px 28px;
        color: white;
        margin-bottom: 28px;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 20px;
        position: relative;
        overflow: hidden;
    }

    .td-hero::before {
        content: '';
        position: absolute;
        width: 200px;
        height: 200px;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 50%;
        top: -60px;
        right: -60px;
    }

    .td-hero h1 {
        font-size: 22px;
        font-weight: 700;
        margin: 0 0 6px;
    }

    .td-hero p {
        font-size: 13px;
        opacity: 0.8;
        margin: 0;
        max-width: 520px;
    }

    .td-kicker {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 4px 14px;
        border-radius: 99px;
        font-size: 12px;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .td-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
    }

    .td-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 24px;
        box-shadow: var(--shadow-sm);
    }

    .td-card h2 {
        font-size: 16px;
        font-weight: 700;
        color: var(--secondary);
        margin: 0 0 16px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .td-card h2 svg {
        color: var(--primary);
        flex-shrink: 0;
    }

    .skill-item {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 14px;
        margin-bottom: 10px;
        transition: var(--transition);
    }

    .skill-item:hover {
        border-color: rgba(0, 97, 145, 0.15);
    }

    .skill-item .name {
        font-size: 14px;
        font-weight: 600;
        color: var(--secondary);
        margin-bottom: 4px;
    }

    .skill-item .desc {
        font-size: 12px;
        color: var(--text-muted);
        line-height: 1.5;
    }

    .stack-item {
        display: block;
        padding: 12px 16px;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        text-decoration: none;
        transition: var(--transition);
        margin-bottom: 10px;
    }

    .stack-item:hover {
        border-color: var(--primary);
        background: rgba(0, 97, 145, 0.03);
    }

    .stack-item .name {
        font-size: 14px;
        font-weight: 600;
        color: var(--secondary);
    }

    .stack-item .arrow {
        float: right;
        color: var(--text-muted);
        transition: var(--transition);
    }

    .stack-item:hover .arrow {
        color: var(--primary);
        transform: translateX(3px);
    }

    .empty-message {
        font-size: 13px;
        color: var(--text-muted);
        font-style: italic;
        padding: 16px 0;
    }

    @@media (max-width: 768px) {
        .td-hero {
            flex-direction: column;
            text-align: center;
        }

        .td-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="td-hero">
    <div>
        <div class="td-kicker">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                <path d="M2 17l10 5 10-5"/>
                <path d="M2 12l10 5 10-5"/>
            </svg>
            Track Details
        </div>
        <h1>@Model.TrackName</h1>
        <p>@Model.TrackDescription</p>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.RoadMapUrl))
    {
        <a href="@Model.RoadMapUrl" target="_blank" rel="noopener noreferrer" class="btn-action" style="display:inline-flex;align-items:center;gap:8px;padding:10px 22px;border-radius:var(--radius-sm);font-size:14px;font-weight:600;text-decoration:none;background:rgba(255,255,255,0.15);color:white;border:1px solid rgba(255,255,255,0.25);flex-shrink:0;transition:var(--transition);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/>
                <line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/>
            </svg>
            Open Roadmap
        </a>
    }
</div>

<div class="td-grid">
    <div class="td-card">
        <h2>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                <path d="M2 17l10 5 10-5"/>
                <path d="M2 12l10 5 10-5"/>
            </svg>
            Skills
        </h2>
        @if (Model.GainedSkills.Any())
        {
            foreach (var skill in Model.GainedSkills)
            {
                <div class="skill-item">
                    <div class="name">@skill.Name</div>
                    <div class="desc">@skill.Description</div>
                </div>
            }
        }
        else
        {
            <div class="empty-message">No skills are currently exposed for this track.</div>
        }
    </div>

    <div class="td-card">
        <h2>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
            </svg>
            Stacks
        </h2>
        @if (Model.Stacks.Any())
        {
            foreach (var stack in Model.Stacks)
            {
                <a href="/Assessment/Stack/@stack.Id" class="stack-item">
                    <span class="name">@stack.StackName</span>
                    <span class="arrow">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="9 18 15 12 9 6"/>
                        </svg>
                    </span>
                </a>
            }
        }
        else
        {
            <div class="empty-message">No stacks are currently exposed for this track.</div>
        }
    </div>
</div>
