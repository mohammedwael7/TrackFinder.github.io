@model TrackFinder.ViewModels.Assessment_ViewModels.TrackStackVM
@inject TrackFinder.Context.AppDbContext DbContext
@using Microsoft.EntityFrameworkCore

@{
    ViewData["Title"] = "Stack Details";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";

    var stackName = Model?.StackName;
    var stackDescription = Model?.StackDescription;

    var toolsList = new List<TrackFinder.Models.AssessmentModels.Tools>();

    if (Model == null)
    {
        var stackIdString = ViewContext.RouteData.Values["stackId"]?.ToString()
                            ?? ViewContext.RouteData.Values["id"]?.ToString()
                            ?? ViewContext.HttpContext.Request.Query["stackId"].ToString();

        if (int.TryParse(stackIdString, out var stackId))
        {
            var dbStack = await DbContext.TrackStacks
                .Include(s => s.RelatedStackTools)
                    .ThenInclude(st => st.RelatedTool)
                .FirstOrDefaultAsync(s => s.Id == stackId);

            if (dbStack != null)
            {
                stackName = dbStack.StackName;
                stackDescription = dbStack.StackDescription;
                toolsList = dbStack.RelatedStackTools?
                    .Select(st => st.RelatedTool)
                    .Where(t => t != null)
                    .ToList() ?? new List<TrackFinder.Models.AssessmentModels.Tools>();
            }
        }
    }
    else
    {
        if (Model.Tools != null && Model.Tools.Any())
        {
            var toolNames = Model.Tools
                .Select(x => x.Name)
                .ToList();

            toolsList = await DbContext.Tools
                .Where(t => toolNames.Contains(t.Name))
                .ToListAsync();

            foreach (var tool in Model.Tools)
            {
                if (!toolsList.Any(t => t.Name.Equals(tool.Name, StringComparison.OrdinalIgnoreCase)))
                {
                    toolsList.Add(new TrackFinder.Models.AssessmentModels.Tools
                    {
                        Name = tool.Name,
                        Description = string.IsNullOrWhiteSpace(tool.Description)
                            ? "No description available."
                            : tool.Description
                    });
                }
            }
        }
    }
}

<style>
    .stack-header {
        background: linear-gradient(135deg, var(--secondary) 0%, var(--primary-dark) 100%);
        border-radius: var(--radius-lg);
        padding: 32px 28px;
        color: white;
        margin-bottom: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        position: relative;
        overflow: hidden;
    }

    .stack-header::before {
        content: '';
        position: absolute;
        width: 200px;
        height: 200px;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 50%;
        top: -60px;
        right: -60px;
    }

    .stack-header h1 {
        font-size: 20px;
        font-weight: 700;
        margin: 0 0 4px;
    }

    .stack-header p {
        font-size: 13px;
        opacity: 0.8;
        margin: 0;
        max-width: 520px;
    }

    .stack-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 4px 14px;
        border-radius: 99px;
        font-size: 12px;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .count-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 16px;
        border-radius: 99px;
        font-size: 13px;
        font-weight: 600;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: white;
        flex-shrink: 0;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: var(--text-muted);
        text-decoration: none;
        margin-bottom: 16px;
        font-weight: 500;
        transition: var(--transition);
    }

    .back-link:hover {
        color: var(--primary);
    }

    .tools-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }

    .tools-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }

    .tools-table thead th {
        background: var(--bg);
        padding: 14px 20px;
        text-align: left;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--text-muted);
        border-bottom: 1px solid var(--border);
    }

    .tools-table tbody td {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        color: var(--text);
        vertical-align: top;
    }

    .tools-table tbody tr:last-child td {
        border-bottom: none;
    }

    .tools-table tbody tr:hover {
        background: rgba(0, 97, 145, 0.02);
    }

    .tool-tag {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 99px;
        font-size: 13px;
        font-weight: 600;
        background: #d1fae5;
        color: #065f46;
        border: 1px solid rgba(16, 185, 129, 0.2);
    }

    .tool-desc {
        font-size: 13px;
        color: var(--text-muted);
        line-height: 1.6;
    }

    .empty-state {
        text-align: center;
        padding: 48px 24px;
    }

    .empty-state .icon {
        font-size: 36px;
        margin-bottom: 10px;
        opacity: 0.5;
    }

    .empty-state h3 {
        font-size: 18px;
        font-weight: 700;
        color: var(--secondary);
        margin-bottom: 4px;
    }

    .empty-state p {
        font-size: 14px;
        color: var(--text-muted);
        margin: 0;
    }

    @@media (max-width: 640px) {
        .stack-header {
            flex-direction: column;
            text-align: center;
            padding: 24px 20px;
        }

        .tools-table thead {
            display: none;
        }

        .tools-table tbody tr {
            display: block;
            padding: 16px;
            border-bottom: 1px solid var(--border);
        }

        .tools-table tbody td {
            display: block;
            padding: 4px 0;
            border: none;
        }

        .tools-table tbody td:first-child {
            margin-bottom: 6px;
        }
    }
</style>

@if (string.IsNullOrEmpty(stackName))
{
    <div class="empty-state" style="background:var(--surface);border-radius:var(--radius-md);border:1px solid var(--border);">
        <div class="icon">⚠️</div>
        <h3>Stack Not Found</h3>
        <p>We couldn't retrieve the stack details because the specified stack could not be found.</p>
    </div>
}
else
{
    <a href="javascript:history.back()" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"/>
        </svg>
        Go Back
    </a>

    <div class="stack-header">
        <div>
            <div class="stack-badge">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
                </svg>
                Technology Stack
            </div>
            <h1>@stackName</h1>
            <p>@stackDescription</p>
        </div>
        <div class="count-chip">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
            </svg>
            @toolsList.Count Tools
        </div>
    </div>

    <div class="tools-card">
        @if (toolsList == null || !toolsList.Any())
        {
            <div class="empty-state">
                <div class="icon">🔧</div>
                <h3>No tools registered</h3>
                <p>No tools are currently registered for this stack.</p>
            </div>
        }
        else
        {
            <table class="tools-table">
                <thead>
                    <tr>
                        <th style="width:25%;">Tool</th>
                        <th style="width:75%;">Description</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tool in toolsList)
                    {
                        <tr>
                            <td><span class="tool-tag">@tool.Name</span></td>
                            <td class="tool-desc">@tool.Description</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}
