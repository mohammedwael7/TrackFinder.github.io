@model List<TrackFinder.ViewModels.Assessment_ViewModels.AssessmentHistoryItemVM>

@{
    ViewData["Title"] = "Assessment History";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .history-header {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        border-radius: var(--radius-lg);
        padding: 36px 32px;
        color: white;
        margin-bottom: 28px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        position: relative;
        overflow: hidden;
    }

    .history-header::before {
        content: '';
        position: absolute;
        width: 280px;
        height: 280px;
        background: rgba(255, 255, 255, 0.04);
        border-radius: 50%;
        top: -100px;
        right: -80px;
    }

    .history-header h1 {
        font-size: 22px;
        font-weight: 700;
        margin: 0 0 4px;
    }

    .history-header p {
        font-size: 14px;
        opacity: 0.8;
        margin: 0;
        max-width: 500px;
    }

    .history-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 4px 14px;
        border-radius: 99px;
        font-size: 12px;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .btn-action {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 22px;
        border-radius: var(--radius-sm);
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        transition: var(--transition);
        cursor: pointer;
        border: none;
        font-family: inherit;
        flex-shrink: 0;
    }

    .btn-action-light {
        background: rgba(255, 255, 255, 0.15);
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.25);
    }

    .btn-action-light:hover {
        background: rgba(255, 255, 255, 0.25);
        color: white;
    }

    /* ── Table Card ──────────────────────────────────────── */
    .table-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }

    .table-wrap {
        overflow-x: auto;
    }

    .hist-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }

    .hist-table thead th {
        background: var(--bg);
        padding: 14px 20px;
        text-align: left;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--text-muted);
        border-bottom: 1px solid var(--border);
    }

    .hist-table tbody td {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        color: var(--text);
        vertical-align: middle;
    }

    .hist-table tbody tr:last-child td {
        border-bottom: none;
    }

    .hist-table tbody tr:hover {
        background: rgba(0, 97, 145, 0.02);
    }

    .hist-date {
        font-weight: 600;
        color: var(--secondary);
    }

    .hist-time {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 2px;
    }

    .btn-view {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 18px;
        border-radius: var(--radius-sm);
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        transition: var(--transition);
        background: var(--bg);
        color: var(--text);
        border: 1px solid var(--border);
    }

    .btn-view:hover {
        border-color: var(--primary);
        color: var(--primary);
        background: rgba(0, 97, 145, 0.04);
    }

    /* ── Mobile Cards ────────────────────────────────────── */
    .history-cards {
        display: none;
        flex-direction: column;
        gap: 12px;
        padding: 16px;
    }

    .history-card-item {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        transition: var(--transition);
    }

    .history-card-item:hover {
        border-color: rgba(0, 97, 145, 0.2);
    }

    .history-card-item .date {
        font-weight: 600;
        color: var(--secondary);
        font-size: 14px;
    }

    .history-card-item .time {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 2px;
    }

    /* ── Empty State ─────────────────────────────────────── */
    .empty-state {
        text-align: center;
        padding: 48px 24px;
    }

    .empty-state .icon {
        font-size: 40px;
        margin-bottom: 12px;
        opacity: 0.4;
    }

    .empty-state h3 {
        font-size: 18px;
        font-weight: 700;
        color: var(--secondary);
        margin-bottom: 6px;
    }

    .empty-state p {
        font-size: 14px;
        color: var(--text-muted);
        margin-bottom: 20px;
    }

    /* ── Responsive ──────────────────────────────────────── */
    @@media (max-width: 640px) {
        .history-header {
            flex-direction: column;
            text-align: center;
            padding: 28px 20px;
        }

        .history-header p {
            max-width: 100%;
        }

        .table-wrap {
            display: none;
        }

        .history-cards {
            display: flex;
        }
    }

    @@media (min-width: 641px) {
        .history-cards {
            display: none;
        }
        .table-wrap {
            display: block;
        }
    }
</style>

<div class="history-header">
    <div>
        <div class="history-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
            Assessment History
        </div>
        <h1>Your Assessment History</h1>
        <p>Browse your previous career assessments, review detailed recommendations, and track your growth over time.</p>
    </div>
    <a asp-action="Index" asp-controller="Assessment" class="btn-action btn-action-light">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="5 3 19 12 5 21 5 3"/>
        </svg>
        New Assessment
    </a>
</div>

<div class="table-card">
    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <div class="icon">📋</div>
            <h3>No assessments yet</h3>
            <p>Start your first career assessment to see your results here.</p>
            <a asp-action="Take" asp-controller="Assessment" class="btn-action btn-action-light" style="display:inline-flex;color:white;background:var(--primary);border:none;padding:10px 28px;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="5 3 19 12 5 21 5 3"/>
                </svg>
                Start Assessment
            </a>
        </div>
    }
    else
    {
        <!-- Desktop Table -->
        <div class="table-wrap">
            <table class="hist-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th style="text-align:right;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="hist-date">@item.CreatedAt.ToString("dd MMM yyyy")</div>
                                <div class="hist-time">@item.CreatedAt.ToString("HH:mm")</div>
                            </td>
                            <td style="text-align:right;">
                                <a href="/Assessment/Result/@item.AssessmentResultId" class="btn-view">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                        <circle cx="12" cy="12" r="3"/>
                                    </svg>
                                    View Result
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Mobile Cards -->
        <div class="history-cards">
            @foreach (var item in Model)
            {
                <a href="/Assessment/Result/@item.AssessmentResultId" class="history-card-item" style="text-decoration:none;">
                    <div>
                        <div class="date">@item.CreatedAt.ToString("dd MMM yyyy")</div>
                        <div class="time">@item.CreatedAt.ToString("HH:mm")</div>
                    </div>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="9 18 15 12 9 6"/>
                    </svg>
                </a>
            }
        </div>
    }
</div>
