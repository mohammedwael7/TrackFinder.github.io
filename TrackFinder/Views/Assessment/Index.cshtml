@{
    ViewData["Title"] = "Assessment";
}
<div class="assessment-landing d-flex flex-column align-items-center justify-content-center text-center py-5" style="min-height: 60vh; max-width: 700px; margin: 0 auto;">
    <span class="badge tf-badge-soft px-3 py-2 mb-3">Career Assessment</span>
    <h1 class="h2 fw-bold text-brand-ink mb-3">Find Your Perfect Technology Track</h1>
    <p class="text-brand-muted mb-5">
        Take a quick assessment to discover which technology track best matches your skills and interests,
        or check your previous assessment results.
    </p>
    <div class="d-flex flex-column flex-sm-row gap-3">
        <a asp-controller="Assessment" asp-action="Take" class="btn btn-brand rounded-pill px-5 py-3 fw-semibold">
            Start Assessment <i class="bi bi-chevron-right ms-1"></i>
        </a>
        <a asp-controller="Assessment" asp-action="History" class="btn btn-brand-outline rounded-pill px-5 py-3 fw-semibold">
            Assessments History <i class="bi bi-clock-history ms-1"></i>
        </a>
    </div>
</div>
