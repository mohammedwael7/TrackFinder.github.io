@{
    ViewData["Title"] = "Assessment";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .assessment-hero {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        border-radius: var(--radius-lg);
        padding: 48px 40px;
        color: white;
        margin-bottom: 36px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 32px;
        position: relative;
        overflow: hidden;
    }

    .assessment-hero::before {
        content: '';
        position: absolute;
        width: 320px;
        height: 320px;
        background: rgba(255, 255, 255, 0.04);
        border-radius: 50%;
        top: -120px;
        right: -80px;
    }

    .assessment-hero::after {
        content: '';
        position: absolute;
        width: 180px;
        height: 180px;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 50%;
        bottom: -60px;
        left: 20%;
    }

    .hero-icon-wrap {
        width: 72px;
        height: 72px;
        background: rgba(255, 255, 255, 0.15);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .hero-content {
        flex: 1;
        min-width: 0;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 5px 14px;
        border-radius: 99px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 12px;
    }

    .hero-title {
        font-size: 26px;
        font-weight: 700;
        letter-spacing: -0.5px;
        margin-bottom: 8px;
    }

    .hero-desc {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.8);
        line-height: 1.6;
        max-width: 560px;
    }

    .process-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 36px;
    }

    .process-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 28px 24px;
        box-shadow: var(--shadow-sm);
        transition: var(--transition);
        position: relative;
    }

    .process-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-md);
        border-color: rgba(0, 97, 145, 0.15);
    }

    .process-step {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(0, 97, 145, 0.08);
        color: var(--primary);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        font-weight: 700;
        margin-bottom: 14px;
    }

    .process-card h3 {
        font-size: 16px;
        font-weight: 700;
        color: var(--secondary);
        margin-bottom: 6px;
    }

    .process-card p {
        font-size: 13px;
        color: var(--text-muted);
        line-height: 1.6;
        margin: 0;
    }

    .cta-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 36px 24px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-sm);
    }

    .cta-section h2 {
        font-size: 20px;
        font-weight: 700;
        color: var(--secondary);
        margin-bottom: 6px;
    }

    .cta-section p {
        font-size: 14px;
        color: var(--text-muted);
        margin-bottom: 24px;
        max-width: 480px;
    }

    .cta-buttons {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .btn-cta {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 14px 32px;
        border-radius: var(--radius-sm);
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        text-decoration: none;
        transition: var(--transition);
        font-family: inherit;
    }

    .btn-cta-primary {
        background: var(--primary);
        color: white;
    }

    .btn-cta-primary:hover {
        background: var(--primary-dark);
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(0, 97, 145, 0.25);
    }

    .btn-cta-secondary {
        background: var(--bg);
        color: var(--text);
        border: 1px solid var(--border);
    }

    .btn-cta-secondary:hover {
        border-color: var(--primary);
        color: var(--primary);
        transform: translateY(-2px);
    }

    @@media (max-width: 768px) {
        .assessment-hero {
            flex-direction: column;
            text-align: center;
            padding: 32px 24px;
        }

        .hero-desc {
            max-width: 100%;
        }

        .process-grid {
            grid-template-columns: 1fr;
        }

        .cta-buttons {
            flex-direction: column;
            width: 100%;
        }

        .btn-cta {
            width: 100%;
            justify-content: center;
        }
    }

    @@media (min-width: 769px) and (max-width: 1024px) {
        .process-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>

<div class="assessment-hero">
    <div class="hero-icon-wrap">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
            <path d="M2 17l10 5 10-5"/>
            <path d="M2 12l10 5 10-5"/>
        </svg>
    </div>
    <div class="hero-content">
        <div class="hero-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"/>
            </svg>
            AI-Powered Career Assessment
        </div>
        <div class="hero-title">Find Your Perfect Technology Track</div>
        <div class="hero-desc">
            Answer a few targeted questions about your interests and experience.
            Our AI matching engine analyzes your responses and recommends the ideal tech career path tailored to you.
        </div>
    </div>
</div>

<div class="process-grid">
    <div class="process-card">
        <div class="process-step">1</div>
        <h3>Answer Questions</h3>
        <p>Complete a short set of questions about your technical interests, problem-solving style, and career goals.</p>
    </div>
    <div class="process-card">
        <div class="process-step">2</div>
        <h3>AI Analysis</h3>
        <p>Our engine evaluates your answers against real industry track data to find the strongest skill matches.</p>
    </div>
    <div class="process-card">
        <div class="process-step">3</div>
        <h3>Get Recommendations</h3>
        <p>Receive your top 3 recommended technology tracks with similarity scores, salary data, and learning roadmaps.</p>
    </div>
</div>

<div class="cta-section">
    <h2>Ready to discover your path?</h2>
    <p>Start the assessment now or review your past results to track your growth over time.</p>
    <div class="cta-buttons">
        <a asp-controller="Assessment" asp-action="Take" class="btn-cta btn-cta-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="5 3 19 12 5 21 5 3"/>
            </svg>
            Start Assessment
        </a>
        <a asp-controller="Assessment" asp-action="History" class="btn-cta btn-cta-secondary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
            </svg>
            View History
        </a>
    </div>
</div>
