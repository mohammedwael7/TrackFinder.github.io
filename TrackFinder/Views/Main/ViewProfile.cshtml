@model TrackFinder.ViewModels.Profile_ViewModels.PublicProfileVM
@{
    ViewData["Title"] = "@" + Model.UserName;
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .profile-layout {
        display: grid;
        grid-template-columns: 1fr 2.5fr;
        gap: 32px;
        align-items: start;
    }

    .profile-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 32px 24px;
        box-shadow: var(--shadow-sm);
        text-align: center;
    }

    .avatar-display {
        width: 140px;
        height: 140px;
        margin: 0 auto 20px;
        border-radius: 50%;
        overflow: hidden;
        border: 3px solid var(--primary);
        box-shadow: var(--shadow-md);
    }

    .avatar-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .avatar-placeholder-large {
        width: 100%;
        height: 100%;
        background: var(--primary);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 48px;
    }

    .profile-name {
        font-size: 20px;
        font-weight: 700;
        color: var(--secondary);
    }

    .profile-username {
        font-size: 14px;
        color: var(--text-muted);
        margin-top: 4px;
    }

    .profile-role-badge {
        display: inline-block;
        margin-top: 10px;
        padding: 4px 14px;
        border-radius: 99px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        background: rgba(0, 97, 145, 0.08);
        color: var(--primary);
    }

    .info-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 36px;
        box-shadow: var(--shadow-sm);
    }

    .section-title {
        font-size: 17px;
        font-weight: 700;
        color: var(--secondary);
        border-bottom: 1.5px solid var(--border);
        padding-bottom: 10px;
        margin-bottom: 24px;
        margin-top: 36px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .section-title:first-of-type {
        margin-top: 0;
    }

    .info-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .info-item {
        margin-bottom: 20px;
    }

    .info-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 4px;
    }

    .info-value {
        font-size: 15px;
        font-weight: 500;
        color: var(--secondary);
    }

    .bio-text {
        font-size: 14px;
        color: var(--text);
        line-height: 1.6;
        white-space: pre-wrap;
    }

    .link-value {
        color: var(--primary);
        text-decoration: none;
    }

    .link-value:hover {
        text-decoration: underline;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--text-muted);
        font-size: 14px;
        font-weight: 500;
        margin-bottom: 20px;
        transition: var(--transition);
    }

    .back-link:hover {
        color: var(--primary);
    }

    @@media (max-width: 900px) {
        .profile-layout {
            grid-template-columns: 1fr;
        }
        .info-grid-2 {
            grid-template-columns: 1fr;
        }
    }
</style>

<a href="javascript:history.back()" class="back-link">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <polyline points="15 18 9 12 15 6"/>
    </svg>
    Back
</a>

<div class="profile-layout">
    <!-- Left Column: Avatar & Basic Info -->
    <div class="profile-card">
        <div class="avatar-display">
            @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
            {
                <img src="@Model.ProfilePictureUrl" alt="@Model.FirstName" class="avatar-img" />
            }
            else
            {
                <div class="avatar-placeholder-large">@Model.FirstName.Substring(0, 1).ToUpper()</div>
            }
        </div>

        <div class="profile-name">@Model.FirstName @Model.LastName</div>
        <div class="profile-username">@@@Model.UserName</div>
        <div class="profile-role-badge">@Model.Role</div>
    </div>

    <!-- Right Column: Detailed Info -->
    <div class="info-card">
        <h1 style="font-size:24px; font-weight:700; color: var(--secondary); margin-bottom:8px;">@Model.FirstName @Model.LastName</h1>
        <p style="font-size:14px; color: var(--text-muted); margin-bottom:32px;">
            @(Model.Role == "Instructor" ? "Instructor Profile" : "Student Profile")
        </p>

        <!-- Section 1: Personal Details -->
        <div class="section-title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
            Personal Details
        </div>

        <div class="info-grid-2">
            <div class="info-item">
                <div class="info-label">First Name</div>
                <div class="info-value">@Model.FirstName</div>
            </div>
            <div class="info-item">
                <div class="info-label">Last Name</div>
                <div class="info-value">@(Model.LastName ?? "-")</div>
            </div>
        </div>

        <div class="info-grid-2">
            <div class="info-item">
                <div class="info-label">Birth Date</div>
                <div class="info-value">@Model.Birthdate.ToString("MMM dd, yyyy")</div>
            </div>
            <div class="info-item">
                <div class="info-label">Gender</div>
                <div class="info-value">@(Model.Gender ?? "-")</div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Bio))
        {
            <div class="info-item">
                <div class="info-label">Bio</div>
                <div class="bio-text">@Model.Bio</div>
            </div>
        }

        <!-- Section 2: Role-Specific Details -->
        @if (Model.Role.Equals("Student", StringComparison.OrdinalIgnoreCase))
        {
            <div class="section-title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                    <path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/>
                </svg>
                Education & Academic Profile
            </div>

            <div class="info-grid-2">
                <div class="info-item">
                    <div class="info-label">Education State</div>
                    <div class="info-value">@(Model.EducationState ?? "-")</div>
                </div>
                <div class="info-item">
                    <div class="info-label">School / University</div>
                    <div class="info-value">@(Model.SchoolOrUnversityName ?? "-")</div>
                </div>
            </div>

            <div class="info-grid-2">
                <div class="info-item">
                    <div class="info-label">Major</div>
                    <div class="info-value">@(Model.Major ?? "-")</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Minor</div>
                    <div class="info-value">@(Model.Minor ?? "-")</div>
                </div>
            </div>

            <div class="info-grid-2">
                <div class="info-item">
                    <div class="info-label">Degree Program</div>
                    <div class="info-value">@(Model.DegreeProgram ?? "-")</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Academic Year</div>
                    <div class="info-value">@Model.AcademicYear</div>
                </div>
            </div>

            <div class="info-item">
                <div class="info-label">GPA</div>
                <div class="info-value">@Model.GPA.ToString("F2")</div>
            </div>
        }
        else if (Model.Role.Equals("Instructor", StringComparison.OrdinalIgnoreCase))
        {
            <div class="section-title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                    <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                </svg>
                Professional Details
            </div>

            <div class="info-item">
                <div class="info-label">Professional Title</div>
                <div class="info-value">@(Model.Title ?? "-")</div>
            </div>

            <div class="info-grid-2">
                <div class="info-item">
                    <div class="info-label">GitHub</div>
                    <div class="info-value">
                        @if (!string.IsNullOrEmpty(Model.GithubLink))
                        {
                            <a href="@Model.GithubLink" target="_blank" class="link-value">@Model.GithubLink</a>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </div>
                </div>
                <div class="info-item">
                    <div class="info-label">LinkedIn</div>
                    <div class="info-value">
                        @if (!string.IsNullOrEmpty(Model.LinkedInLink))
                        {
                            <a href="@Model.LinkedInLink" target="_blank" class="link-value">@Model.LinkedInLink</a>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>
