@using TrackFinder.Models.CourseModels
@model TrackFinder.Models.CourseModels.Course

@{
    ViewData["Title"] = "Edit Course";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="breadcrumb">
            <a asp-controller="CourseCreation" asp-action="Index">Courses</a>
            <span>›</span>
            <a asp-controller="CourseCreation" asp-action="Details" asp-route-id="@Model.Id">@Model.Name</a>
            <span>›</span>
            <span>Edit</span>
        </div>
        <h1 class="page-title">Edit Course</h1>
        <p class="page-sub">Update details for <strong style="color:var(--text)">@Model.Name</strong>.</p>
    </div>
    <div class="action-row">
        <a asp-controller="CourseCreation" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-ghost btn-sm">← Back</a>
        <a asp-controller="CourseCreation" asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger btn-sm"
           onclick="return confirm('Delete this course permanently?')">Delete</a>
    </div>
</div>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <div class="card">
        <div class="card-title">Course Details</div>
        <div class="card-subtitle">Changes will be reflected immediately after saving.</div>

        <div class="form-grid">
            <div class="form-group full">
                <label asp-for="Name">Course Title <span class="req">*</span></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="field-validation-error"></span>
            </div>

            <div class="form-group full">
                <label asp-for="Description">Description</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Price">Price (USD) <span class="req">*</span></label>
                <input asp-for="Price" type="number" step="0.01" min="0" class="form-control" />
                <span asp-validation-for="Price" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Discount">Discount (%)</label>
                <input asp-for="Discount" type="number" step="0.1" min="0" max="100" class="form-control" />
                <span asp-validation-for="Discount" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Language">Language <span class="req">*</span></label>
                <select asp-for="Language" class="form-control" asp-items="Html.GetEnumSelectList<Language>()"></select>
                <span asp-validation-for="Language" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Level">Level <span class="req">*</span></label>
                <select asp-for="Level" class="form-control" asp-items="Html.GetEnumSelectList<Level>()"></select>
                <span asp-validation-for="Level" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label>Duration</label>
                <div class="duration-row">
                    <div>
                        <input asp-for="Duration.Value" type="number" min="1" class="form-control" />
                        <span asp-validation-for="Duration.Value" class="field-validation-error"></span>
                    </div>
                    <div>
                        <select asp-for="Duration.DurationIn" class="form-control" asp-items="Html.GetEnumSelectList<DurationIn>()"></select>
                        <span asp-validation-for="Duration.DurationIn" class="field-validation-error"></span>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Rating">Rating (0–5)</label>
                <input asp-for="Rating" type="number" step="0.1" min="0" max="5" class="form-control" />
                <span asp-validation-for="Rating" class="field-validation-error"></span>
            </div>

            <div class="form-group full">
                <label asp-for="ImageUrl">Thumbnail URL</label>
                <input asp-for="ImageUrl" type="url" class="form-control" />
                <span asp-validation-for="ImageUrl" class="field-validation-error"></span>
                @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                {
                    <div class="current-url-hint">Current: <a href="@Model.ImageUrl" target="_blank">@Model.ImageUrl</a></div>
                }
            </div>
        </div>

    </div>

    <div class="card">
        <div class="card-title">Skills Gained</div>
        <div class="card-subtitle">Pick one or more skills students will gain from this course.</div>

        <div class="skills-grid">
            @{
                var gainedSkills = (List<TrackFinder.Models.AssessmentModels.GainedSkill>)ViewBag.GainedSkills;
                var selectedSkillIds = (List<int>)(ViewBag.SelectedSkillIds ?? new List<int>());
            }
            @if (gainedSkills is null || gainedSkills.Count == 0)
            {
                <div class="form-hint">No skills have been set up yet.</div>
            }
            else
            {
                foreach (var skill in gainedSkills)
                {
                    var isChecked = selectedSkillIds.Contains(skill.Id);
                    <label class="skill-option">
                        <input type="checkbox" name="selectedSkillIds" value="@skill.Id" checked="@isChecked" />
                        <span>@skill.Name</span>
                    </label>
                }
            }
        </div>
    </div>

    <div class="card">
        <div class="form-actions">
            <button type="submit" class="btn btn-primary btn-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M2 1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4.414A1 1 0 0 0 14.707 4L12 1.293A1 1 0 0 0 11.293 1H2zm7.5 11.5v-2a.5.5 0 0 0-.5-.5H7a.5.5 0 0 0-.5.5v2h-2v-7h9v7h-2z" />
                </svg>
                Save Changes
            </button>
            <a asp-controller="CourseCreation" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-ghost">Discard</a>
        </div>
    </div>
</form>