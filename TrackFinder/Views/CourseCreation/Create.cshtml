@using TrackFinder.Models.CourseModels
@model TrackFinder.Models.CourseModels.Course

@{
    ViewData["Title"] = "Create Course";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="breadcrumb">
            <a asp-controller="CourseCreation" asp-action="Index">Courses</a>
            <span>›</span><span>Create</span>
        </div>
        <h1 class="page-title">Create a New Course</h1>
        <p class="page-sub">Fill in the details below to publish a new course.</p>
    </div>
    <a asp-controller="CourseCreation" asp-action="Index" class="btn btn-ghost">← Back to Courses</a>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <div class="card">
        <div class="card-title">Course Details</div>
        <div class="card-subtitle">Basic information students will see in the catalog.</div>

        <div class="form-grid">
            <div class="form-group full">
                <label asp-for="Name">Course Title <span class="req">*</span></label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Complete ASP.NET Core Mastery" />
                <span asp-validation-for="Name" class="field-validation-error"></span>
            </div>

            <div class="form-group full">
                <label asp-for="Description">Description</label>
                <textarea asp-for="Description" class="form-control" rows="4"
                          placeholder="What will students learn? Give a compelling overview."></textarea>
                <span asp-validation-for="Description" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Price">Price (USD) <span class="req">*</span></label>
                <input asp-for="Price" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
                <span asp-validation-for="Price" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Discount">Discount (%)</label>
                <input asp-for="Discount" type="number" step="0.1" min="0" max="100" class="form-control" placeholder="0 – 100" />
                <span asp-validation-for="Discount" class="field-validation-error"></span>
                <div class="form-hint">Enter 0–100 to apply a percentage discount.</div>
            </div>

            <div class="form-group">
                <label asp-for="Language">Language <span class="req">*</span></label>
                <select asp-for="Language" class="form-control" asp-items="Html.GetEnumSelectList<Language>()">
                    <option value="">— Select language —</option>
                </select>
                <span asp-validation-for="Language" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Level">Level <span class="req">*</span></label>
                <select asp-for="Level" class="form-control" asp-items="Html.GetEnumSelectList<Level>()">
                    <option value="">— Select level —</option>
                </select>
                <span asp-validation-for="Level" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label>Duration</label>
                <div class="duration-row">
                    <div>
                        <input asp-for="Duration.Value" type="number" min="1" class="form-control" placeholder="e.g. 4" />
                        <span asp-validation-for="Duration.Value" class="field-validation-error"></span>
                    </div>
                    <div>
                        <select asp-for="Duration.DurationIn" class="form-control" asp-items="Html.GetEnumSelectList<DurationIn>()">
                            <option value="">— Unit —</option>
                        </select>
                        <span asp-validation-for="Duration.DurationIn" class="field-validation-error"></span>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Rating">Initial Rating (0–5)</label>
                <input asp-for="Rating" type="number" step="0.1" min="0" max="5" class="form-control" placeholder="0.0" />
                <span asp-validation-for="Rating" class="field-validation-error"></span>
            </div>

            <div class="form-group full">
                <label asp-for="ImageUrl">Thumbnail URL</label>
                <input asp-for="ImageUrl" type="url" class="form-control"
                       placeholder="https://example.com/course-thumbnail.jpg" />
                <span asp-validation-for="ImageUrl" class="field-validation-error"></span>
                <div class="form-hint">Paste a public image URL. Recommended: 1280×720 px.</div>
            </div>
        </div>

    </div>

    <div class="card">
        <div class="card-title">Skills Gained</div>
        <div class="card-subtitle">Pick one or more skills students will gain from this course.</div>

        <div class="skills-grid">
            @{
                var gainedSkills = (List<TrackFinder.Models.AssessmentModels.GainedSkill>)ViewBag.GainedSkills;
            }
            @if (gainedSkills is null || gainedSkills.Count == 0)
            {
                <div class="form-hint">No skills have been set up yet.</div>
            }
            else
            {
                foreach (var skill in gainedSkills)
                {
                    <label class="skill-option">
                        <input type="checkbox" name="selectedSkillIds" value="@skill.Id" />
                        <span>@skill.Name</span>
                    </label>
                }
            }
        </div>
    </div>

    <div class="card">
        <div class="form-actions">
            <button type="submit" class="btn btn-primary btn-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M10.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425z" />
                </svg>
                Publish Course
            </button>
            <a asp-controller="CourseCreation" asp-action="Index" class="btn btn-ghost">Cancel</a>
        </div>
    </div>
</form>