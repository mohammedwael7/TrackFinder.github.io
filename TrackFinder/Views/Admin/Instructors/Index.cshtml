@model IEnumerable<TrackFinder.Models.UserModels.Instructor>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Instructors</h3>
    <a class="btn btn-primary" asp-controller="Instructors" asp-action="Create">New Instructor</a>
</div>

<table class="table table-hover bg-white shadow-sm rounded">
    <thead>
        <tr>
            <th>Name</th>
            <th>Title</th>
            <th>Rating</th>
            <th>Actions</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach(var item in Model ?? Enumerable.Empty<TrackFinder.Models.UserModels.Instructor>()){
            <tr>
                <td>@item.User?.FirstName @item.User?.LastName</td>
                <td>@item.Title</td>
                <td>@item.Rating</td>
          
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary me-1" asp-action="Details" asp-route-userId="@item.UserId">Details</a>
                    <a class="btn btn-sm btn-outline-secondary me-1" asp-action="Edit" asp-route-userId="@item.UserId">Edit</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-userId="@item.UserId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>