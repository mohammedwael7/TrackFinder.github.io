@model TrackFinder.ViewModels.Achievements.BadgeDetailsViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>@Model.BadgeName</h3>
    <div>
        <a class="btn btn-outline-secondary me-1" asp-action="Edit" asp-route-id="@Model.BadgeId">Edit</a>
        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.BadgeId">Delete</a>
    </div>
</div>

<div class="card p-3 bg-white shadow-sm">
    @if(!string.IsNullOrEmpty(Model.BadgeImageUrl)){
        <img src="@Model.BadgeImageUrl" class="img-fluid mb-3" style="max-width:200px" />
    }
    <p class="text-muted">@Model.BadgeDescription</p>
</div>