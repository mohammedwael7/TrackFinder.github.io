@model IEnumerable<TrackFinder.ViewModels.Communities.CommunityListViewModel>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Communities</h3>
    <a class="btn btn-primary" asp-controller="Communities" asp-action="Create">New Community</a>
</div>

<table class="table table-hover bg-white shadow-sm rounded">
    <thead>
        <tr>
            <th>Name</th>
            <th>Admin</th>
            <th>Members</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model ?? Enumerable.Empty<TrackFinder.ViewModels.Communities.CommunityListViewModel>())
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.AdminName</td>
                <td>@item.MemberCount</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary me-1" asp-action="Details" asp-route-id="@item.Id">Details</a>
                    <a class="btn btn-sm btn-outline-secondary me-1" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>