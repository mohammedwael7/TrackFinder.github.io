@model TrackFinder.ViewModels.Communities.EditCommunityViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h3>Edit Community</h3>

<form asp-action="Edit" asp-controller="Communities" method="post" asp-route-id="@Model.Id">
    @Html.AntiForgeryToken()

    <input asp-for="Id" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="5"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">
        Save Changes
    </button>

    <a asp-action="Index" asp-controller="Communities" class="btn btn-secondary ms-2">
        Cancel
    </a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}