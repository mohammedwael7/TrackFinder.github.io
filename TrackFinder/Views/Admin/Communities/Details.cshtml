@model TrackFinder.ViewModels.Communities.CommunityDetailsViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">@Model.Name</h2>
        <span class="text-muted">
            Community Details
        </span>
    </div>

    <div>
        <a asp-action="Edit"
           asp-route-id="@Model.Id"
           class="btn btn-warning me-2">
            <i class="bi bi-pencil-square"></i> Edit
        </a>

        <a asp-action="Delete"
           asp-route-id="@Model.Id"
           class="btn btn-danger">
            <i class="bi bi-trash"></i> Delete
        </a>
    </div>
</div>

<div class="card shadow-lg border-0 rounded-4 overflow-hidden">

    <div class="card-header bg-primary text-white py-4">
        <div class="d-flex align-items-center">

            <div class="rounded-circle bg-white text-primary d-flex justify-content-center align-items-center"
                 style="width:70px;height:70px;font-size:28px;">
                <i class="bi bi-people-fill"></i>
            </div>

            <div class="ms-3">
                <h3 class="mb-1">@Model.Name</h3>
                <small>Track Finder Community</small>
            </div>

        </div>
    </div>

    <div class="card-body p-4">

        <div class="row g-4">

            <div class="col-md-4">
                <div class="border rounded-3 p-3 text-center h-100">

                    <i class="bi bi-person-badge fs-2 text-primary"></i>

                    <h6 class="mt-3 text-muted">
                        Community Admin
                    </h6>

                    <h5 class="fw-bold">
                        @Model.AdminName
                    </h5>

                </div>
            </div>

            <div class="col-md-4">
                <div class="border rounded-3 p-3 text-center h-100">

                    <i class="bi bi-people fs-2 text-success"></i>

                    <h6 class="mt-3 text-muted">
                        Members
                    </h6>

                    <h4 class="fw-bold">
                        @Model.MemberCount
                    </h4>

                </div>
            </div>

            <div class="col-md-4">
                <div class="border rounded-3 p-3 text-center h-100">

                    <i class="bi bi-hash fs-2 text-warning"></i>

                    <h6 class="mt-3 text-muted">
                        Community ID
                    </h6>

                    <small class="fw-semibold">
                        @Model.Id
                    </small>

                </div>
            </div>

        </div>

        <hr class="my-4" />

        <h5 class="fw-bold mb-3">
            <i class="bi bi-card-text text-primary"></i>
            Description
        </h5>

        <div class="bg-light rounded-3 p-4">

            @if (string.IsNullOrWhiteSpace(Model.Description))
            {
                <span class="text-muted">
                    No description available.
                </span>
            }
            else
            {
                @Model.Description
            }

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}