@model IEnumerable<TrackFinder.ViewModels.Settings.SettingListViewModel>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Settings</h3>
    <a class="btn btn-primary" asp-action="Create" asp-controller="Settings">New Setting</a>
</div>

<div class="card p-3 bg-white shadow-sm">
    <table class="table">
        <thead>
            <tr>
                <th>Key</th>
                <th>Value</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach(var item in Model ?? Enumerable.Empty<TrackFinder.ViewModels.Settings.SettingListViewModel>()){
                <tr>
                    <td>@item.Key</td>
                    <td>@item.Value</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary me-1" asp-action="Details" asp-route-id="@item.Id">Details</a>
                        <a class="btn btn-sm btn-outline-secondary me-1" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
