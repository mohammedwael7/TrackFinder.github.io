@model TrackFinder.ViewModels.Tracks.TrackDetailsViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-1">
                @Model.TrackName
            </h2>

            <p class="text-muted mb-0">
                View complete track information
            </p>
        </div>

        <div>

            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn btn-warning me-2">
                <i class="bi bi-pencil-square me-1"></i>
                Edit
            </a>

            <a asp-action="Delete"
               asp-route-id="@Model.Id"
               class="btn btn-outline-danger">
                <i class="bi bi-trash me-1"></i>
                Delete
            </a>

        </div>

    </div>

    <div class="row g-4">

        <!-- Left Card -->
        <div class="col-lg-4">

            <div class="card shadow border-0 rounded-4">

                <div class="card-body text-center py-5">

                    <div class="mb-4">

                        <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center"
                             style="width:120px;height:120px;">

                            <i class="bi bi-diagram-3 text-primary"
                               style="font-size:55px;"></i>

                        </div>

                    </div>

                    <h3 class="fw-bold">
                        @Model.TrackName
                    </h3>

                    <span class="badge bg-primary px-3 py-2 mt-2">
                        Learning Track
                    </span>

                </div>

            </div>

        </div>

        <!-- Right Card -->
        <div class="col-lg-8">

            <div class="card shadow border-0 rounded-4">

                <div class="card-header bg-white border-0 py-3">

                    <h5 class="fw-bold mb-0">
                        Track Information
                    </h5>

                </div>

                <div class="card-body">

                    <div class="mb-4">

                        <label class="text-muted small fw-semibold">
                            Track Name
                        </label>

                        <div class="fs-5">
                            @Model.TrackName
                        </div>

                    </div>

                    <div class="mb-4">

                        <label class="text-muted small fw-semibold">
                            Description
                        </label>

                        <div class="border rounded-3 bg-light p-3">

                            @if (string.IsNullOrWhiteSpace(Model.TrackDescription))
                            {
                                <span class="text-muted">
                                    No description available.
                                </span>
                            }
                            else
                            {
                                @Model.TrackDescription
                            }

                        </div>

                    </div>

                    <div>

                        <label class="text-muted small fw-semibold">
                            Roadmap
                        </label>

                        @if (!string.IsNullOrWhiteSpace(Model.RoadMapUrl))
                        {
                            <div class="mt-2">

                                <a href="@Model.RoadMapUrl"
                                   target="_blank"
                                   class="btn btn-outline-primary">

                                    <i class="bi bi-box-arrow-up-right me-1"></i>

                                    Open Roadmap

                                </a>

                            </div>
                        }
                        else
                        {
                            <div class="text-muted mt-2">
                                No roadmap available.
                            </div>
                        }

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}