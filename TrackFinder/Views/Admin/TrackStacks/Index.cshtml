@model IEnumerable<TrackFinder.ViewModels.TrackStacks.TrackStackListViewModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Track Stacks</h2>
            <small class="text-muted">
                Manage all track stacks
            </small>
        </div>

        <a asp-action="Create"
           asp-controller="TrackStacks"
           class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>
            New Track Stack
        </a>
    </div>

    <div class="card shadow-sm border-0">

        <div class="card-header bg-white">
            <h5 class="mb-0">
                Track Stacks List
            </h5>
        </div>

        <div class="card-body">

            @if (!Model.Any())
            {
                <div class="alert alert-info mb-0">
                    No Track Stacks Found.
                </div>
            }
            else
            {
                <table class="table table-hover align-middle">

                    <thead class="table-light">

                        <tr>

                            <th>Stack Name</th>

                            <th>Related Track</th>

                            <th>Description</th>

                            <th>Courses</th>

                            <th width="220"></th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    <strong>
                                        @item.StackName
                                    </strong>
                                </td>

                                <td>
                                    @item.RelatedTrackName
                                </td>

                                <td>

                                    @if (string.IsNullOrWhiteSpace(item.StackDescription))
                                    {
                                        <span class="text-muted">
                                            No Description
                                        </span>
                                    }
                                    else
                                    {
                                        @(item.StackDescription.Length > 60
                                                                    ? item.StackDescription.Substring(0, 60) + "..."
                                                                    : item.StackDescription)
                                    }

                                </td>

                                <td>

                                    <span class="badge bg-success">

                                        @item.CoursesCount Courses

                                    </span>

                                </td>

                                <td class="text-end">

                                    <a asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary">

                                        Details

                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-warning">

                                        Edit

                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger">

                                        Delete

                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>
            }

        </div>

    </div>

</div>