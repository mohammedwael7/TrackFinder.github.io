@model TrackFinder.ViewModels.Students.StudentDetailsViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">
            <i class="bi bi-mortarboard-fill text-primary me-2"></i>
            Student Details
        </h2>
        <p class="text-muted mb-0">
            View complete student information
        </p>
    </div>

    <div>
        <a asp-action="Edit"
           asp-route-userId="@Model.UserId"
           class="btn btn-warning me-2">
            <i class="bi bi-pencil-square"></i> Edit
        </a>

        <a asp-action="Delete"
           asp-route-userId="@Model.UserId"
           class="btn btn-danger">
            <i class="bi bi-trash"></i> Delete
        </a>
    </div>
</div>

<div class="card shadow-lg border-0 rounded-4 overflow-hidden">

    <div class="card-header bg-primary text-white py-4">
        <div class="d-flex align-items-center">

            <div class="rounded-circle bg-white text-primary d-flex justify-content-center align-items-center me-3"
                 style="width:80px;height:80px;font-size:30px;">
                <i class="bi bi-person-fill"></i>
            </div>

            <div>
                <h3 class="mb-1">@Model.StudentName</h3>

                <span class="badge bg-light text-dark px-3 py-2">
                    Student ID
                </span>

                <small class="d-block mt-2 opacity-75">
                    @Model.UserId
                </small>
            </div>

        </div>
    </div>

    <div class="card-body p-4">

        <div class="row g-4">

            <div class="col-md-6">
                <div class="border rounded-3 p-3 h-100">

                    <h5 class="text-primary mb-3">
                        <i class="bi bi-building"></i>
                        Education
                    </h5>

                    <p>
                        <strong>Education State</strong><br />
                        @(string.IsNullOrWhiteSpace(Model.EducationState)
                                                ? "-"
                                                : Model.EducationState)
                    </p>

                    <p>
                        <strong>University</strong><br />
                        @(string.IsNullOrWhiteSpace(Model.SchoolOrUnversityName)
                                                ? "-"
                                                : Model.SchoolOrUnversityName)
                    </p>

                    <p class="mb-0">
                        <strong>Academic Year</strong><br />
                        <span class="badge bg-success fs-6">
                            @Model.AcademicYear
                        </span>
                    </p>

                </div>
            </div>

            <div class="col-md-6">
                <div class="border rounded-3 p-3 h-100">

                    <h5 class="text-primary mb-3">
                        <i class="bi bi-journal-code"></i>
                        Academic Info
                    </h5>

                    <p>
                        <strong>Major</strong><br />
                        @(string.IsNullOrWhiteSpace(Model.Major)
                                                ? "-"
                                                : Model.Major)
                    </p>

                    <p>
                        <strong>Minor</strong><br />
                        @(string.IsNullOrWhiteSpace(Model.Minor)
                                                ? "-"
                                                : Model.Minor)
                    </p>

                    <p>
                        <strong>Degree Program</strong><br />
                        @(string.IsNullOrWhiteSpace(Model.DegreeProgram)
                                                ? "-"
                                                : Model.DegreeProgram)
                    </p>

                    <p class="mb-0">
                        <strong>GPA</strong><br />

                        <span class="badge bg-info text-dark fs-6 px-3 py-2">
                            @Model.GPA
                        </span>
                    </p>

                </div>
            </div>

            <div class="col-12">

                <div class="border rounded-3 p-3">

                    <h5 class="text-primary mb-3">
                        <i class="bi bi-file-earmark-text"></i>
                        Biography
                    </h5>

                    @if (string.IsNullOrWhiteSpace(Model.Bio))
                    {
                        <span class="text-muted">
                            No biography available.
                        </span>
                    }
                    else
                    {
                        <p class="mb-0">
                            @Model.Bio
                        </p>
                    }

                </div>

            </div>

        </div>

    </div>

</div>