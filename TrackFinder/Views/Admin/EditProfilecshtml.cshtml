@model TrackFinder.ViewModels.Users.EditUserViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="card shadow border-0 rounded-4">

            <div class="card-header bg-transparent border-0 py-4">

                <h3 class="fw-bold">

                    Edit Profile

                </h3>

            </div>

            <div class="card-body">

                <form asp-action="EditProfile"
                      method="post"
                      enctype="multipart/form-data">

                    @Html.AntiForgeryToken()

                    <input asp-for="Id" type="hidden" />

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-3">

                            <label asp-for="FirstName" class="form-label"></label>

                            <input asp-for="FirstName"
                                   class="form-control" />

                            <span asp-validation-for="FirstName"
                                  class="text-danger"></span>

                        </div>

                        <div class="col-md-6 mb-3">

                            <label asp-for="LastName"
                                   class="form-label"></label>

                            <input asp-for="LastName"
                                   class="form-control" />

                            <span asp-validation-for="LastName"
                                  class="text-danger"></span>

                        </div>

                    </div>

                    <div class="mb-3">

                        <label asp-for="Username"
                               class="form-label"></label>

                        <input asp-for="Username"
                               class="form-control" />

                    </div>

                    <div class="mb-3">

                        <label asp-for="Email"
                               class="form-label"></label>

                        <input asp-for="Email"
                               class="form-control" />

                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-3">

                            <label asp-for="Birthdate"
                                   class="form-label"></label>

                            <input asp-for="Birthdate"
                                   type="date"
                                   class="form-control" />

                        </div>


                    </div>

                    <div class="mb-3">

                        <label asp-for="Bio"
                               class="form-label"></label>

                        <textarea asp-for="Bio"
                                  rows="5"
                                  class="form-control">
                        </textarea>

                    </div>

                    <div class="mb-4">

                        <label class="form-label">

                            Profile Picture

                        </label>

                        <input asp-for="Image" type="file" class="form-control" />

                    </div>

                    <div class="d-flex justify-content-end">

                        <a asp-action="Profile"
                           class="btn btn-light me-2">

                            Cancel

                        </a>

                        <button class="btn btn-primary">

                            <i class="bi bi-check-circle"></i>

                            Save Changes

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}