@model TrackFinder.ViewModels.Admin_ViewModels.AdminDashboardVM

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">


    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold">
                Dashboard
            </h2>

            <p class="text-muted">
                Welcome back, Admin 👋
            </p>
        </div>

        @if (Context.Request.Query["error"] == "1")
        {
            <div class="alert alert-warning alert-dismissible fade show mt-3" role="alert">
                <strong>Something went wrong.</strong> The previous operation did not complete successfully. Please try again.
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

    </div>



    <!-- Statistics Cards -->

    <div class="row g-4">


        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-card">

                <div class="card-body">

                    <div class="icon-box bg-primary">
                        <i class="bi bi-people"></i>
                    </div>

                    <h6>Total Users</h6>

                    <h2>
                        @Model.UsersCount
                    </h2>

                </div>

            </div>
        </div>

        <div class="col-xl-3 col-md-6">

            <div class="card dashboard-card">

                <div class="card-body">


                    <div class="icon-box bg-info">
                        <i class="bi bi-person-video3"></i>
                    </div>


                    <h6>
                        Instructors
                    </h6>


                    <h2>
                        @Model.InstructorsCount
                    </h2>


                </div>

            </div>

        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-card">

                <div class="card-body">

                    <div class="icon-box bg-success">
                        <i class="bi bi-mortarboard"></i>
                    </div>

                    <h6>Students</h6>

                    <h2>
                        @Model.StudentsCount
                    </h2>

                </div>

            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-card">

                <div class="card-body">

                    <div class="icon-box bg-warning">
                        <i class="bi bi-hourglass-split"></i>
                    </div>

                    <h6>Pending Instructors</h6>

                    <h2>
                        @Model.PendingInstructors
                    </h2>

                </div>

            </div>
        </div>



    </div>





    <!-- Second Row -->

    <div class="row g-4 mt-2">


        <div class="col-lg-6">

            <div class="card shadow border-0 rounded-4">

                <div class="card-body">

                    <h5 class="fw-bold mb-3">
                        Students vs Instructors
                    </h5>


                    <canvas id="usersChart"></canvas>


                </div>

            </div>

        </div>





        <div class="col-lg-6">

            <div class="card shadow border-0 rounded-4">

                <div class="card-body">


                    <h5 class="fw-bold mb-3">
                        System Overview
                    </h5>


                    <canvas id="systemChart"></canvas>


                </div>

            </div>

        </div>



    </div>






    <!-- Pending Instructor Requests -->


    <div class="card shadow border-0 rounded-4 mt-4">


        <div class="card-body">


            <div class="d-flex justify-content-between mb-3">

                <h5 class="fw-bold">
                    Pending Instructor Requests
                </h5>


                <a asp-controller="Instructors"
                   asp-action="Index"
                   class="btn btn-primary btn-sm">

                    View All

                </a>


            </div>



            <div class="table-responsive">

                <table class="table align-middle">


                    <thead>

                        <tr>

                            <th>Name</th>

                            <th>Email</th>

                            <th>Title</th>

                            <th>Date</th>

                        </tr>

                    </thead>



                    <tbody>


                        @foreach (var item in Model.PendingInstructorRequests)
                        {

                            <tr>

                                <td>
                                    @item.Name
                                </td>


                                <td>
                                    @item.Email
                                </td>


                                <td>
                                    @item.Title
                                </td>


                                <td>
                                    @item.CreatedAt.ToString("dd MMM yyyy")
                                </td>


                            </tr>

                        }


                    </tbody>


                </table>


            </div>


        </div>


    </div>





    <!-- Latest Users -->


    <div class="card shadow border-0 rounded-4 mt-4">


        <div class="card-body">


            <h5 class="fw-bold mb-3">
                Latest Registered Users
            </h5>



            <div class="table-responsive">

                <table class="table">


                    <thead>

                        <tr>

                            <th>Name</th>

                            <th>Email</th>

                            <th>Role</th>

                            <th>Joined</th>

                        </tr>

                    </thead>



                    <tbody>


                        @foreach (var user in Model.LatestUsers)
                        {

                            <tr>

                                <td>
                                    @user.Name
                                </td>


                                <td>
                                    @user.Email
                                </td>


                                <td>

                                    <span class="badge bg-primary">
                                        @user.Role
                                    </span>

                                </td>


                                <td>
                                    @user.CreatedAt.ToString("dd MMM yyyy")
                                </td>


                            </tr>

                        }


                    </tbody>


                </table>


            </div>


        </div>


    </div>



</div>





@section Scripts {


    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>


    <script>


        new Chart(document.getElementById('usersChart'), {

            type:'doughnut',

            data:{

                labels:[
                    'Students',
                    'Instructors'
                ],


                datasets:[{

                    data:[

                        @Model.StudentsCount,

                        @Model.InstructorsCount

                    ],

                    backgroundColor: [
                        '#198754',
                        '#0dcaf0'
                    ]

                }]

            }

        });





        new Chart(document.getElementById('systemChart'),{

            type:'bar',

            data:{

                labels:[

                    'Courses',

                    'Instructors',
                    'Students',

                    'Communities',
                    'Certificates',
                    'Badges'

                ],


                datasets:[{

                    label:'Count',

                    data:[

                        @Model.CoursesCount,

                        @Model.InstructorsCount,
                        @Model.StudentsCount,

                        @Model.CommunitiesCount,

                        @Model.CertificatesCount,

                        @Model.BadgesCount

                    ]

                }]

            }

        });


    </script>

}