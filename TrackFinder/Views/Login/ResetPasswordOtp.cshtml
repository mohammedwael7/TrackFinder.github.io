@model TrackFinder.ViewModels.Auth_ViewModels.ResetPasswordOtpVM
@{
    ViewData["Title"] = "Reset Password";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    var email = ViewBag.Email as string ?? Model?.Email ?? "";
}

<div class="auth-header">
    <img src="~/images/Logo.png" alt="Track Finder Logo" class="auth-logo" />
    <div class="auth-brand">Track Finder</div>
    <div class="auth-tagline">CS Learning Portal</div>
</div>

<div class="auth-card">
    <div style="text-align:center;margin-bottom:8px;">
        <div style="width:56px;height:56px;background:#e5eeff;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;margin-bottom:16px;">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#006191" stroke-width="2">
                <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 7L2 7"/>
            </svg>
        </div>
        <h1 style="font-size:22px;font-weight:700;color:#0b1c30;margin-bottom:8px;">Check Your Email</h1>
        <p style="font-size:14px;color:#3f4850;line-height:1.6;">
            We sent a password reset code to<br />
            <strong style="color:#006191;">@email</strong>
        </p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-success" style="margin-top:16px;">✓ @TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-error" style="margin-top:16px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            @TempData["ErrorMessage"]
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert-error" style="margin-top:16px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            @Html.ValidationSummary(true)
        </div>
    }

    <form asp-action="ResetPasswordOtp" asp-controller="Login" method="post" id="otpForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Email" value="@email" />

        <div class="otp-inputs" role="group" aria-label="Enter 6-digit code">
            @for (int i = 0; i < 6; i++)
            {
                <input type="text" class="otp-input" id="otp_@i"
                       maxlength="1" inputmode="numeric" pattern="[0-9]"
                       autocomplete="one-time-code"
                       aria-label="Digit @(i+1)" />
            }
        </div>
        <input type="hidden" asp-for="OtpCode" id="otpCodeHidden" />

        <button type="submit" class="btn-primary" id="verifyBtn">Verify Code</button>
    </form>

    <div style="text-align:center;margin-top:20px;">
        <p style="font-size:13px;color:#6f7881;margin-bottom:8px;">
            Didn't receive a code?
        </p>
        <form asp-action="ResendPasswordResetOtp" asp-controller="Login" method="post" style="display:inline;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="email" value="@email" />
            <button type="submit" id="resendBtn"
                    style="background:none;border:none;color:#006191;font-size:14px;font-weight:600;
                           cursor:pointer;font-family:inherit;padding:0;"
                    onclick="startResendCooldown(this)">
                Resend Code
            </button>
        </form>
        <span id="cooldownTimer" style="font-size:13px;color:#a0aab4;display:none;"></span>
    </div>

    <div style="text-align:center;margin-top:16px;">
        <a href="/Login" style="font-size:13px;color:#6f7881;text-decoration:none;">
            ← Back to Sign In
        </a>
    </div>
</div>

@section Scripts {
<script>
    const inputs = document.querySelectorAll('.otp-input');
    const hidden  = document.getElementById('otpCodeHidden');

    inputs.forEach((input, idx) => {
        input.addEventListener('input', function (e) {
            this.value = this.value.replace(/[^0-9]/g, '').slice(-1);
            updateHidden();
            if (this.value && idx < inputs.length - 1)
                inputs[idx + 1].focus();
        });

        input.addEventListener('keydown', function (e) {
            if (e.key === 'Backspace' && !this.value && idx > 0) {
                inputs[idx - 1].focus();
                inputs[idx - 1].value = '';
                updateHidden();
            }
        });

        input.addEventListener('paste', function (e) {
            e.preventDefault();
            const pasted = (e.clipboardData || window.clipboardData)
                            .getData('text').replace(/[^0-9]/g, '').slice(0, 6);
            pasted.split('').forEach((ch, i) => {
                if (inputs[i]) inputs[i].value = ch;
            });
            updateHidden();
            const next = inputs[Math.min(pasted.length, inputs.length - 1)];
            if (next) next.focus();
        });
    });

    function updateHidden() {
        hidden.value = Array.from(inputs).map(i => i.value).join('');
    }

    document.getElementById('otpForm').addEventListener('submit', function (e) {
        updateHidden();
        if (hidden.value.length < 6) {
            e.preventDefault();
            alert('Please enter all 6 digits of the verification code.');
            inputs[0].focus();
            return;
        }
        const btn = document.getElementById('verifyBtn');
        btn.disabled = true;
        btn.textContent = 'Verifying...';
    });

    function startResendCooldown(btn) {
        let seconds = 15;
        const timer = document.getElementById('cooldownTimer');
        setTimeout(function () {
            btn.disabled = true;
            btn.style.display = 'none';
            timer.style.display = 'inline';
            timer.textContent = 'Resend in ' + seconds + 's';
            const interval = setInterval(function () {
                seconds--;
                timer.textContent = 'Resend in ' + seconds + 's';
                if (seconds <= 0) {
                    clearInterval(interval);
                    timer.style.display = 'none';
                    btn.style.display = 'inline';
                    btn.disabled = false;
                }
            }, 1000);
        }, 100);
    }

    inputs[0]?.focus();
</script>
}
