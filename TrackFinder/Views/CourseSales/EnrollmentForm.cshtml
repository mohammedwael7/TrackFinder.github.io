@using TrackFinder.Models.CourseModels
@using TrackFinderDb.Models.TeachingModels
@model Enrollment

@{
    ViewData["Title"] = "Payment";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .enroll-wrap {
        max-width: 480px;
        margin: 0 auto;
    }

    .enroll-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 32px;
        box-shadow: var(--shadow-sm);
    }

    .enroll-header {
        text-align: center;
        margin-bottom: 28px;
    }

    .enroll-header .icon-box {
        width: 56px;
        height: 56px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 14px;
    }

    .enroll-header h1 {
        font-size: 20px;
        font-weight: 700;
        color: var(--secondary);
        margin: 0 0 4px;
    }

    .enroll-header p {
        font-size: 13px;
        color: var(--text-muted);
        margin: 0;
    }

    .form-group {
        margin-bottom: 18px;
    }

    .form-group label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: var(--secondary);
        margin-bottom: 6px;
    }

    .form-group input {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        font-size: 14px;
        font-family: inherit;
        color: var(--text);
        background: var(--surface);
        transition: var(--transition);
        box-sizing: border-box;
    }

    .form-group input:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(0, 97, 145, 0.1);
    }

    .form-group .field-validation-error {
        font-size: 12px;
        color: #ef4444;
        margin-top: 4px;
        display: block;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    .enroll-actions {
        display: flex;
        gap: 12px;
        margin-top: 28px;
        padding-top: 20px;
        border-top: 1px solid var(--border);
    }

    .enroll-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 12px 24px;
        border-radius: var(--radius-sm);
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        transition: var(--transition);
        cursor: pointer;
        border: none;
        font-family: inherit;
        flex: 1;
    }

    .enroll-btn-primary {
        background: var(--primary);
        color: white;
    }

    .enroll-btn-primary:hover {
        background: var(--primary-dark);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(0, 97, 145, 0.2);
    }

    .enroll-btn-secondary {
        background: var(--bg);
        color: var(--text);
        border: 1px solid var(--border);
    }

    .enroll-btn-secondary:hover {
        border-color: var(--primary);
        color: var(--primary);
    }
</style>

<div class="enroll-wrap">
    <div class="enroll-card">
        <div class="enroll-header">
            <div class="icon-box">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="1" y="4" width="22" height="16" rx="2"/>
                    <line x1="1" y1="10" x2="23" y2="10"/>
                </svg>
            </div>
            <h1>Payment Information</h1>
            <p>Secure enrollment checkout</p>
        </div>

        <form asp-action="EnrollCourse" method="post">
            <div class="form-group">
                <label>Card Number</label>
                <input type="password" asp-for="CardNumber" placeholder="Card Number" />
                <span asp-validation-for="CardNumber" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Expiry Date</label>
                    <input asp-for="ExpiryDate" placeholder="MM/YY" />
                    <span asp-validation-for="ExpiryDate" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label>CVV</label>
                    <input type="password" asp-for="CVV" placeholder="CVV" />
                    <span asp-validation-for="CVV" class="field-validation-error"></span>
                </div>
            </div>

            <input type="hidden" asp-for="CourseId" />

            <div class="enroll-actions">
                <button type="submit" class="enroll-btn enroll-btn-primary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Enroll Now
                </button>
                <button type="button" class="enroll-btn enroll-btn-secondary" onclick="history.back()">Back</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
