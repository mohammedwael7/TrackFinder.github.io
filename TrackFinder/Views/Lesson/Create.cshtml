@model TrackFinder.Models.CourseModels.Lesson

@{
    ViewData["Title"] = "Add Lesson";
}

<link rel="stylesheet" href="~/css/Lesson/create.css" asp-append-version="true" />

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-text">
        <div class="header-breadcrumb">
            <a asp-controller="Course" asp-action="Index">Courses</a>
            @* @if (Model.CourseId.HasValue)
            { *@
            <span>›</span>
            <a asp-controller="Course" asp-action="Details" asp-route-id="@Model.CourseId">Course Details</a>
            @* } *@
            <span>›</span>
            <span>Add Lesson</span>
        </div>
        <h1>Add a New Lesson</h1>
        <p>Create a lesson and attach it to your course.</p>
    </div>
    @* @if (Model.CourseId.HasValue)
    { *@
    <a asp-controller="Course" asp-action="Details" asp-route-id="@Model.CourseId" class="btn btn-ghost">
        ← Back to Course
    </a>
    @* } *@
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="CourseId" />

    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <div class="card">
        <div class="card-title">Lesson Details</div>
        <div class="card-subtitle">Fill in the information for your new lesson.</div>

        <div class="form-grid">
            <!-- Name -->
            <div class="form-group full">
                <label asp-for="Name">Lesson Title <span class="req">*</span></label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Introduction to Dependency Injection" />
                <span asp-validation-for="Name" class="field-validation-error"></span>
            </div>

            <!-- Description -->
            <div class="form-group full">
                <label asp-for="Description">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"
                          placeholder="What will students learn in this lesson?"></textarea>
                <span asp-validation-for="Description" class="field-validation-error"></span>
            </div>

            <!-- Price -->
            <div class="form-group">
                <label asp-for="Price">Price (USD) <span class="req">*</span></label>
                <input asp-for="Price" type="number" min="0" class="form-control" placeholder="0" />
                <span asp-validation-for="Price" class="field-validation-error"></span>
            </div>

            <!-- Discount -->
            <div class="form-group">
                <label asp-for="Discount">Discount (%)</label>
                <input asp-for="Discount" type="number" step="0.1" min="0" max="100" class="form-control" placeholder="0 – 100" />
                <span asp-validation-for="Discount" class="field-validation-error"></span>
            </div>

            <!-- Duration -->
            <div class="form-group full">
                <label>Duration</label>
                <div class="duration-row">
                    <div>
                        <input asp-for="Duration.Minutes" type="number" min="0" class="form-control" placeholder="Minutes" />
                        <span asp-validation-for="Duration.Minutes" class="field-validation-error"></span>
                    </div>
                    <div>
                        <input asp-for="Duration.Seconds" type="number" min="0" max="59" class="form-control" placeholder="Seconds (0–59)" />
                        <span asp-validation-for="Duration.Seconds" class="field-validation-error"></span>
                    </div>
                </div>
                <div class="form-hint">Enter the total watch time for this lesson.</div>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary btn-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M10.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425z" />
                </svg>
                Save Lesson
            </button>
            @* @if (Model.CourseId.HasValue) *@
            @* { *@
            <a asp-controller="Course" asp-action="Details" asp-route-id="@Model.CourseId" class="btn btn-ghost">Cancel</a>
            @* } *@
            @* else
            {
            <a asp-controller="Course" asp-action="Index" class="btn btn-ghost">Cancel</a>
            } *@
        </div>
    </div>
</form>