@model TrackFinder.Models.CourseModels.Lesson

@{
    ViewData["Title"] = "Edit Lesson";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-text">
        <div class="header-breadcrumb">
            <a asp-controller="CourseCreation" asp-action="Index">Courses</a>
            @* @if (Model.CourseId.HasValue) *@
            @* { *@
            <span>›</span>
            <a asp-controller="CourseCreation" asp-action="Details" asp-route-id="@Model.CourseId">Course Details</a>
            @* } *@
            <span>›</span>
            <a asp-controller="Lesson" asp-action="Details" asp-route-id="@Model.Id">@Model.Name</a>
            <span>›</span>
            <span>Edit</span>
        </div>
        <h1>Edit Lesson</h1>
        <p>Update the details for <strong style="color:var(--text)">@Model.Name</strong>.</p>
    </div>
    <div class="action-row">
        <a asp-controller="Lesson" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-ghost btn-sm">← Back</a>
        <a asp-controller="Lesson" asp-action="Delete" asp-route-id="@Model.Id"
           class="btn btn-danger btn-sm"
           onclick="return confirm('Delete this lesson permanently?')">Delete</a>
    </div>
</div>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CourseId" />

    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <div class="card">
        <div class="card-title">Lesson Details</div>
        <div class="card-subtitle">Your changes will be saved immediately.</div>

        <div class="form-grid">
            <!-- Name -->
            <div class="form-group full">
                <label asp-for="Name">Lesson Title <span class="req">*</span></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="field-validation-error"></span>
            </div>

            <!-- Description -->
            <div class="form-group full">
                <label asp-for="Description">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="field-validation-error"></span>
            </div>

            <!-- Price -->
            <div class="form-group">
                <label asp-for="Price">Price (USD) <span class="req">*</span></label>
                <input asp-for="Price" type="number" min="0" class="form-control" />
                <span asp-validation-for="Price" class="field-validation-error"></span>
            </div>

            <!-- Discount -->
            <div class="form-group">
                <label asp-for="Discount">Discount (%)</label>
                <input asp-for="Discount" type="number" step="0.1" min="0" max="100" class="form-control" />
                <span asp-validation-for="Discount" class="field-validation-error"></span>
            </div>

            <!-- Duration -->
            <div class="form-group full">
                <label>Duration</label>
                <div class="duration-row">
                    <div>
                        <input asp-for="Duration.Minutes" type="number" min="0" class="form-control" placeholder="Minutes" />
                        <span asp-validation-for="Duration.Minutes" class="field-validation-error"></span>
                    </div>
                    <div>
                        <input asp-for="Duration.Seconds" type="number" min="0" max="59" class="form-control" placeholder="Seconds (0–59)" />
                        <span asp-validation-for="Duration.Seconds" class="field-validation-error"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary btn-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M2 1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4.414A1 1 0 0 0 14.707 4L12 1.293A1 1 0 0 0 11.293 1H2zm7.5 11.5v-2a.5.5 0 0 0-.5-.5H7a.5.5 0 0 0-.5.5v2h-2v-7h9v7h-2zM9.5 4V2H10v2H8.5V2h-1v2H6V2.5h.5V4H9.5z" />
                </svg>
                Save Changes
            </button>
            <a asp-controller="Lesson" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-ghost">Discard</a>
        </div>
    </div>
</form>