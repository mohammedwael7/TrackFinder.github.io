@using TrackFinder.Models.CourseModels
@using TrackFinderDb.Models.TeachingModels
@model Course

@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var enrollment = ViewBag.Enrollment as Enrollment;
}

<style>
    .course-header {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        border-radius: var(--radius-lg);
        padding: 36px 32px;
        color: white;
        margin-bottom: 28px;
        position: relative;
        overflow: hidden;
    }
    .course-header h1 { font-size: 22px; font-weight: 700; margin: 0 0 4px; }
    .course-header p { font-size: 14px; opacity: 0.8; margin: 0; }
    .course-header .meta { font-size: 13px; opacity: 0.7; margin-top: 8px; display: flex; gap: 16px; }

    .progress-section {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 20px 24px;
        margin-bottom: 24px;
    }
    .progress-section .bar-bg { height: 8px; background: var(--border); border-radius: 99px; overflow: hidden; }
    .progress-section .bar-fill { height: 100%; background: linear-gradient(90deg, var(--primary), var(--primary-light)); border-radius: 99px; }
    .progress-section .label { font-size: 13px; color: var(--text-muted); margin-top: 6px; display: block; }

    .lesson-list { display: flex; flex-direction: column; gap: 12px; }
    .lesson-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 16px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        transition: var(--transition);
        text-decoration: none;
        color: inherit;
    }
    .lesson-card:hover {
        border-color: var(--primary);
        box-shadow: var(--shadow-sm);
        transform: translateX(4px);
    }
    .lesson-card .info { flex: 1; }
    .lesson-card .info h4 { font-size: 15px; font-weight: 600; margin: 0 0 2px; color: var(--secondary); }
    .lesson-card .info p { font-size: 13px; color: var(--text-muted); margin: 0; }
    .lesson-card .badge {
        font-size: 12px;
        padding: 4px 12px;
        border-radius: 99px;
        font-weight: 600;
        white-space: nowrap;
    }
    .lesson-card .badge.materials { background: #dbeafe; color: #1e40af; }
    .lesson-card .badge.exam { background: #fef3c7; color: #92400e; }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 14px;
        color: var(--text-muted);
        text-decoration: none;
        margin-bottom: 16px;
    }
    .back-link:hover { color: var(--primary); }

    .empty-state {
        text-align: center;
        padding: 48px 24px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
    }
    .empty-state .icon { font-size: 40px; margin-bottom: 8px; opacity: 0.5; }
    .empty-state h3 { font-size: 16px; font-weight: 700; color: var(--secondary); margin-bottom: 4px; }
    .empty-state p { font-size: 13px; color: var(--text-muted); margin: 0; }

    @@media (max-width: 767.98px) {
        .course-header { padding: 24px 20px; }
        .course-header h1 { font-size: 22px; }
        .lesson-list { gap: 10px; }
        .back-link { margin-bottom: 16px; }
    }
    @@media (max-width: 575.98px) {
        .course-header { padding: 20px 16px; border-radius: var(--radius-md); }
        .course-header h1 { font-size: 18px; }
        .course-header .header-stat { font-size: 12px; }
        .empty-state { padding: 32px 16px; }
    }
</style>

<a asp-action="MyCourses" asp-controller="CourseSales" class="back-link">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    Back to My Courses
</a>

<div class="course-header">
    <h1>@Model.Name</h1>
    <p>@Model.Description</p>
    <div class="meta">
        <span>@(Model.Lessons?.Count ?? 0) lessons</span>
        @if (Model.Lessons != null)
        {
            var total = Model.Lessons.Sum(l => l.Duration?.Minutes ?? 0);
            <span>@total min</span>
        }
    </div>
</div>

@if (enrollment != null)
{
    <div class="progress-section">
        <div class="bar-bg">
            <div class="bar-fill" style="width:@(enrollment.Progress)%"></div>
        </div>
        <span class="label">@enrollment.Progress% complete (@enrollment.CompletedLessons of @(Model.Lessons?.Count ?? 0) lessons)</span>
    </div>
}

@if (Model.Lessons != null && Model.Lessons.Any())
{
    <div class="lesson-list">
        @foreach (var lesson in Model.Lessons.OrderBy(l => l.Duration?.Minutes ?? 0))
        {
            <a asp-action="Lesson" asp-controller="Course" asp-route-courseId="@Model.Id" asp-route-lessonId="@lesson.Id" class="lesson-card">
                <div class="info">
                    <h4>@lesson.Name</h4>
                    @if (!string.IsNullOrEmpty(lesson.Description))
                    {
                        <p>@lesson.Description</p>
                    }
                </div>
                <div style="display:flex;gap:8px;align-items:center;">
                    @if (lesson.Materials != null && lesson.Materials.Any())
                    {
                        <span class="badge materials">@lesson.Materials.Count materials</span>
                    }
                    @if (lesson.Exams != null && lesson.Exams.Any())
                    {
                        <span class="badge exam">@lesson.Exams.Count exam</span>
                    }
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </div>
            </a>
        }
    </div>
}
else
{
    <div class="empty-state">
        <div class="icon">📖</div>
        <h3>No lessons yet</h3>
        <p>This course doesn't have any lessons right now.</p>
    </div>
}
