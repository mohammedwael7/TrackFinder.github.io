@using TrackFinder.Models.CourseModels
@model Lesson

@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .lesson-header {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 24px 28px;
        margin-bottom: 24px;
    }
    .lesson-header h1 { font-size: 20px; font-weight: 700; color: var(--secondary); margin: 0 0 4px; }
    .lesson-header p { font-size: 14px; color: var(--text-muted); margin: 0; }
    .lesson-header .meta { font-size: 13px; color: var(--text-muted); margin-top: 8px; display: flex; gap: 16px; }

    .materials-section { margin-bottom: 24px; }
    .materials-section h3 { font-size: 16px; font-weight: 700; color: var(--secondary); margin-bottom: 12px; }
    .material-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 12px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 8px;
        text-decoration: none;
        color: var(--text);
        transition: var(--transition);
    }
    .material-card:hover { border-color: var(--primary); }
    .material-card .icon { font-size: 20px; }
    .material-card .name { font-size: 14px; font-weight: 500; flex: 1; }
    .material-card .type { font-size: 12px; color: var(--text-muted); }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 14px;
        color: var(--text-muted);
        text-decoration: none;
        margin-bottom: 16px;
    }
    .back-link:hover { color: var(--primary); }

    .exam-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #fef3c7;
        color: #92400e;
        padding: 4px 12px;
        border-radius: 99px;
        font-size: 12px;
        font-weight: 600;
    }
</style>

<a asp-action="Index" asp-controller="Course" asp-route-id="@Model.CourseId" class="back-link">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    Back to Course
</a>

<div class="lesson-header">
    <h1>@Model.Name</h1>
    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <p>@Model.Description</p>
    }
    <div class="meta">
        @if (Model.Duration != null)
        {
            <span>Duration: @Model.Duration.Minutes:@Model.Duration.Seconds.ToString("D2")</span>
        }
        @if (Model.Exams != null && Model.Exams.Any())
        {
            <span class="exam-badge">@Model.Exams.Count exam(s)</span>
        }
    </div>
</div>

@if (Model.Materials != null && Model.Materials.Any())
{
    <div class="materials-section">
        <h3>Materials</h3>
        @foreach (var material in Model.Materials)
        {
            <a href="@material.FileUrl" target="_blank" class="material-card">
                <span class="icon">📄</span>
                <span class="name">@material.FileName</span>
                <span class="type">@material.ContentType</span>
            </a>
        }
    </div>
}
else
{
    <p style="color:var(--text-muted);font-size:14px;">No materials for this lesson.</p>
}
