@{
    ViewData["Title"] = "Assign Certificate";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="breadcrumb"><a asp-action="Certificates">Certificates</a><span>›</span><span>Assign</span></div>
        <h1 class="page-title">Assign Certificate</h1>
        <p class="page-sub">Formally issue a certificate milestone to a successful student.</p>
    </div>
</div>

<div class="card" style="max-width:600px;">
    <form asp-action="AssignCertificate" method="post">
        <div class="form-grid">
            <div class="form-group full">
                <label>Select Student</label>
                <select name="studentId" class="form-control">
                    @foreach (var student in ViewBag.Students)
                    {
                        <option value="@student.UserId">@student.User?.Username</option>
                    }
                </select>
            </div>

            <div class="form-group full">
                <label>Select Certificate</label>
                <select name="certificateId" class="form-control">
                    @foreach (var cert in ViewBag.Certificates)
                    {
                        <option value="@cert.Id">@cert.Title</option>
                    }
                </select>
            </div>

            <div class="form-group full">
                <label>Select Related Course</label>
                <select name="courseId" class="form-control">
                    @foreach (var course in ViewBag.Courses)
                    {
                        <option value="@course.Id">@course.Name</option>
                    }
                </select>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Assign Certificate</button>
            <a asp-action="Certificates" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
</div>
