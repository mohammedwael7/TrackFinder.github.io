@model List<TrackFinder.Models.AchievementModels.Badges>
@{
    ViewData["Title"] = "Badges";
}

<div style="background-color: #f8fafc; padding: 2rem; font-family: sans-serif; min-height: 100vh;">
    <div style="max-width: 1100px; margin: 0 auto;">

        <!-- Header -->
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <div>
                <h5 style="color: #1a3a5c; font-weight: 700; margin: 0; font-size: 1.4rem;">Badges</h5>
                <p style="color: #7a8fa6; font-size: 0.88rem; margin: 0; margin-top: 0.25rem;">Manage all badges in the system</p>
            </div>
            <div style="display: flex; gap: 0.75rem;">
                <a asp-action="AssignBadge" style="background: #ffffff; color: #1a3a5c; border: 1.5px solid #dde3ea; padding: 0.6rem 1.25rem; border-radius: 10px; font-size: 0.85rem; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center;">Assign Badge</a>
                <a asp-action="CreateBadge" style="background: linear-gradient(135deg, #2c5282 0%, #3a8fc4 100%); color: white; padding: 0.6rem 1.25rem; border-radius: 10px; font-size: 0.85rem; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; box-shadow: 0 4px 12px rgba(44,82,130,0.15);">+ Add Badge</a>
            </div>
        </div>

        <!-- Table Card -->
        <div style="background: #ffffff; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.01); border: none; overflow: hidden;">
            <table style="width: 100%; border-collapse: collapse; font-size: 0.88rem; text-align: left;">
                <thead style="background: #f8fafc; border-bottom: 1px solid #f0f4f8;">
                    <tr>
                        <th style="padding: 1rem 1.5rem; color: #7a8fa6; font-weight: 600;">Name</th>
                        <th style="padding: 1rem; color: #7a8fa6; font-weight: 600;">Description</th>
                        <th style="padding: 1rem; color: #7a8fa6; font-weight: 600;">Level</th>
                        <th style="padding: 1rem; color: #7a8fa6; font-weight: 600;">Unlock Condition</th>
                        <th style="padding: 1rem 1.5rem; color: #7a8fa6; font-weight: 600; text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var badge in Model)
                    {
                        <tr style="border-bottom: 1px solid #f8fafc;">
                            <td style="padding: 1rem 1.5rem; color: #1a3a5c; font-weight: 600;">
                                <i class="@(badge.BadgeIconClass ?? "bi bi-patch-check")" style="color: #2c5282; margin-right: 0.5rem; font-size: 1.1rem;"></i>
                                @badge.BadgeName
                            </td>
                            <td style="padding: 1rem; color: #555555; max-width: 300px;">@badge.BadgeDescription</td>
                            <td style="padding: 1rem;">
                                <span style="background: #e0f2fe; color: #0369a1; padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 600;">LVL @badge.Level</span>
                            </td>
                            <td style="padding: 1rem; color: #555555;">@badge.UnlockCondition</td>
                            <td style="padding: 1rem 1.5rem; text-align: right; display: flex; gap: 0.5rem; justify-content: flex-end;">
                                <a asp-action="EditBadge" asp-route-id="@badge.BadgeId" style="background: #f0f4f8; color: #1a3a5c; padding: 0.4rem 1rem; border-radius: 8px; font-size: 0.8rem; font-weight: 600; text-decoration: none;">Edit</a>
                                <form asp-action="DeleteBadge" method="post" style="margin: 0; display: inline;">
                                    <input type="hidden" name="id" value="@badge.BadgeId" />
                                    <button type="submit" style="background: #fff0f0; color: #e53e3e; border: none; padding: 0.4rem 1rem; border-radius: 8px; font-size: 0.8rem; font-weight: 600; cursor: pointer;" onclick="return confirm('Delete this badge?')">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>
