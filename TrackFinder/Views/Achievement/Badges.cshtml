@model List<TrackFinder.Models.AchievementModels.Badges>
@{
    ViewData["Title"] = "Badges";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Badges</h1>
        <p class="page-sub">Badges you have earned.</p>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="card" style="padding:40px;text-align:center;color:var(--text-muted);">
        <p>No badges earned yet.</p>
    </div>
}
else
{
    <div class="table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Level</th>
                    <th>Unlock Condition</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var badge in Model)
                {
                    <tr>
                        <td style="font-weight:600;color:var(--secondary);">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" style="margin-right:6px;vertical-align:middle;"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
                            @badge.BadgeName
                        </td>
                        <td style="color:var(--text-muted);max-width:300px;">@badge.BadgeDescription</td>
                        <td><span class="badge badge-sky">LVL @badge.Level</span></td>
                        <td style="color:var(--text-muted);">@badge.UnlockCondition</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
