@model List<TrackFinder.Models.AchievementModels.Certificate>
@{
    ViewData["Title"] = "Certificates";
}

<div style="background-color: #f8fafc; padding: 2rem; font-family: sans-serif; min-height: 100vh;">
    <div style="max-width: 1100px; margin: 0 auto;">

        <!-- Header -->
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <div>
                <h5 style="color: #1a3a5c; font-weight: 700; margin: 0; font-size: 1.4rem;">Certificates</h5>
                <p style="color: #7a8fa6; font-size: 0.88rem; margin: 0; margin-top: 0.25rem;">Manage all certificates in the system</p>
            </div>
            <div style="display: flex; gap: 0.75rem;">
                <a asp-action="AssignCertificate" style="background: #ffffff; color: #1a3a5c; border: 1.5px solid #dde3ea; padding: 0.6rem 1.25rem; border-radius: 10px; font-size: 0.85rem; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center;">Assign Certificate</a>
                <a asp-action="CreateCertificate" style="background: linear-gradient(135deg, #2c5282 0%, #3a8fc4 100%); color: white; padding: 0.6rem 1.25rem; border-radius: 10px; font-size: 0.85rem; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; box-shadow: 0 4px 12px rgba(44,82,130,0.15);">+ Add Certificate</a>
            </div>
        </div>

        <!-- Table Card -->
        <div style="background: #ffffff; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.01); border: none; overflow: hidden;">
            <table style="width: 100%; border-collapse: collapse; font-size: 0.88rem; text-align: left;">
                <thead style="background: #f8fafc; border-bottom: 1px solid #f0f4f8;">
                    <tr>
                        <th style="padding: 1rem 1.5rem; color: #7a8fa6; font-weight: 600;">Title</th>
                        <th style="padding: 1rem; color: #7a8fa6; font-weight: 600;">Description</th>
                        <th style="padding: 1rem; color: #7a8fa6; font-weight: 600;">Unlock Requirement</th>
                        <th style="padding: 1rem 1.5rem; color: #7a8fa6; font-weight: 600; text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cert in Model)
                    {
                        <tr style="border-bottom: 1px solid #f8fafc;">
                            <td style="padding: 1rem 1.5rem; color: #1a3a5c; font-weight: 600;">
                                <i class="bi bi-award" style="color: #2c5282; margin-right: 0.5rem; font-size: 1.1rem;"></i>
                                @cert.Title
                            </td>
                            <td style="padding: 1rem; color: #555555; max-width: 400px;">@cert.Description</td>
                            <td style="padding: 1rem; color: #555555;">@cert.UnlockRequirement</td>
                            <td style="padding: 1rem 1.5rem; text-align: right; display: flex; gap: 0.5rem; justify-content: flex-end;">
                                <a asp-action="EditCertificate" asp-route-id="@cert.Id" style="background: #f0f4f8; color: #1a3a5c; padding: 0.4rem 1rem; border-radius: 8px; font-size: 0.8rem; font-weight: 600; text-decoration: none;">Edit</a>
                                <form asp-action="DeleteCertificate" method="post" style="margin: 0; display: inline;">
                                    <input type="hidden" name="id" value="@cert.Id" />
                                    <button type="submit" style="background: #fff0f0; color: #e53e3e; border: none; padding: 0.4rem 1rem; border-radius: 8px; font-size: 0.8rem; font-weight: 600; cursor: pointer;" onclick="return confirm('Delete this certificate?')">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>
