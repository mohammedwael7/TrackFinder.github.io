@model List<TrackFinder.Models.AchievementModels.Certificate>
@{
    ViewData["Title"] = "Certificates";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Certificates</h1>
        <p class="page-sub">Manage all certificates in the system.</p>
    </div>
    <div class="action-row">
        <a asp-action="AssignCertificate" class="btn btn-ghost">Assign Certificate</a>
        <a asp-action="CreateCertificate" class="btn btn-primary">+ Add Certificate</a>
    </div>
</div>

<div class="table-wrapper">
    <table class="data-table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Description</th>
                <th>Unlock Requirement</th>
                <th style="text-align:right;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cert in Model)
            {
                <tr>
                    <td style="font-weight:600;color:var(--secondary);">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" style="margin-right:6px;vertical-align:middle;"><path d="M12 15l-2-2m0 0l-2 2m2-2V3"/><path d="M6 21h12a2 2 0 002-2v-4a2 2 0 00-2-2H6a2 2 0 00-2 2v4a2 2 0 002 2z"/></svg>
                        @cert.Title
                    </td>
                    <td style="color:var(--text-muted);max-width:400px;">@cert.Description</td>
                    <td style="color:var(--text-muted);">@cert.UnlockRequirement</td>
                    <td style="text-align:right;">
                        <div class="action-row" style="justify-content:flex-end;">
                            <a asp-action="EditCertificate" asp-route-id="@cert.Id" class="btn btn-info btn-sm">Edit</a>
                            <form asp-action="DeleteCertificate" method="post" style="margin:0;display:inline;">
                                <input type="hidden" name="id" value="@cert.Id" />
                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this certificate?')">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
