@model TrackFinder.Models.AchievementModels.Badges
@{
    ViewData["Title"] = "Add Badge";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <div>
        <div class="breadcrumb"><a asp-action="Badges">Badges</a><span>›</span><span>Add</span></div>
        <h1 class="page-title">Add New Badge</h1>
        <p class="page-sub">Create a unique digital insignia to reward milestones.</p>
    </div>
</div>

<div class="card" style="max-width:600px;">
    <form asp-action="CreateBadge" method="post">
        <div class="form-grid">
            <div class="form-group full">
                <label asp-for="BadgeName">Badge Name <span class="req">*</span></label>
                <input asp-for="BadgeName" class="form-control" placeholder="e.g. Speed Coder" />
                <span asp-validation-for="BadgeName" class="field-validation-error"></span>
            </div>

            <div class="form-group full">
                <label asp-for="BadgeDescription">Description</label>
                <input asp-for="BadgeDescription" class="form-control" placeholder="Short description explaining the reward..." />
                <span asp-validation-for="BadgeDescription" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Level">Level</label>
                <input asp-for="Level" type="number" class="form-control" value="1" />
                <span asp-validation-for="Level" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="UnlockCondition">Unlock Condition</label>
                <input asp-for="UnlockCondition" class="form-control" placeholder="e.g. Top 5% in speed tests" />
                <span asp-validation-for="UnlockCondition" class="field-validation-error"></span>
            </div>

            <div class="form-group full">
                <label asp-for="BadgeIconClass">Icon Class</label>
                <input asp-for="BadgeIconClass" class="form-control" placeholder="bi bi-patch-check" />
                <div class="form-hint">Use Bootstrap Icons class names, e.g. <code>bi bi-patch-check</code> or <code>bi bi-lightning</code></div>
                <span asp-validation-for="BadgeIconClass" class="field-validation-error"></span>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Badge</button>
            <a asp-action="Badges" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
</div>
