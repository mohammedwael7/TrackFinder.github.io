<div class="container-xxl py-4">
    <div class="row align-items-center g-3">
        <div class="col-md-6">
            <div class="d-flex align-items-center gap-3">
                <img src="~/images/logo.png" alt="TrackFinder logo" class="footer-logo" />
                <div>
                    <div class="fw-semibold text-brand-ink">TrackFinder</div>
                    <div class="small text-brand-muted">Assessment and recommendation front-end</div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <ul class="footer-links list-unstyled d-flex flex-wrap justify-content-md-end gap-3 mb-0">
                <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li><a asp-controller="Assessment" asp-action="Index">Assessment</a></li>
                <li><a asp-controller="Assessment" asp-action="History">History</a></li>
                <li><a asp-controller="Home" asp-action="Privacy">Privacy</a></li>
            </ul>
        </div>
    </div>
    <div class="footer-divider my-4"></div>
    <div class="d-flex flex-column flex-md-row justify-content-between gap-2 small text-brand-muted">
        <span>&copy; @DateTime.UtcNow.Year TrackFinder</span>
        <span>Built with ASP.NET Core MVC and Bootstrap 5.</span>
    </div>
</div>
