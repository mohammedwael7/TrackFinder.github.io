@model AssessmentResultTracksVM

<article class="recommendation-card card h-100 border-0 rounded-4 overflow-hidden">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
            <div>
                <div class="section-kicker mb-2">Recommended track</div>
                <h3 class="h5 text-brand-ink mb-0">@Model.TrackName</h3>
            </div>
            <span class="score-pill">@Model.SimilarityScore%</span>
        </div>

        <p class="text-brand-muted mb-4">@Model.TrackDescription</p>

        <div class="mb-3">
            <div class="mini-label mb-2">Required skills</div>
            <div class="d-flex flex-wrap gap-2">
                @if (Model.Skills?.Any() == true)
                {
                    foreach (var skill in Model.Skills)
                    {
                        <span class="badge tf-badge rounded-pill">@skill</span>
                    }
                }
                else
                {
                    <span class="text-brand-muted small">No skills exposed by the current data model.</span>
                }
            </div>
        </div>

        <div class="mb-4">
            <div class="mini-label mb-2">Tech stacks</div>
            <div class="d-flex flex-wrap gap-2">
                @if (Model.Stacks?.Any() == true)
                {
                    foreach (var stack in Model.Stacks)
                    {
                        <span class="badge tf-badge-soft rounded-pill">@stack</span>
                    }
                }
                else
                {
                    <span class="text-brand-muted small">No stacks exposed by the current data model.</span>
                }
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-brand rounded-pill px-4" asp-controller="Assessment" asp-action="TrackDetails" asp-route-trackId="@Model.TrackId">View details</a>
            <a class="btn btn-brand-outline rounded-pill px-4" asp-controller="Assessment" asp-action="TrackDetails" asp-route-trackId="@Model.TrackId">More info</a>
        </div>
    </div>
</article>
