@using Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TrackFinder</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" id="bootstrap-css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        html, body {
            margin: 0;
            padding: 0;
        }

        .tf-header,
        .tf-navbar-fixed {
            margin-top: 0 !important;
            top: 0 !important;
        }
    </style>
    <script>
        (function () {
            window.addEventListener("DOMContentLoaded", function () {
                var el = document.createElement("div");
                el.className = "d-none";
                document.body.appendChild(el);
                var loaded = getComputedStyle(el).display === "none";
                document.body.removeChild(el);
                if (!loaded) {
                    console.warn("[TrackFinder] Local Bootstrap CSS failed to load (check wwwroot/lib/bootstrap). Falling back to CDN.");
                    var link = document.createElement("link");
                    link.rel = "stylesheet";
                    link.href = "https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css";
                    document.head.appendChild(link);
                }
            });
        })();
    </script>
</head>
<body class="tf-app">
    <header class="tf-header">
        <nav class="navbar navbar-expand-lg navbar-dark tf-navbar tf-navbar-fixed py-3">
            <div class="container-xxl">
                <a class="navbar-brand d-flex align-items-center gap-3 m-0" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.png" alt="TrackFinder logo" class="navbar-logo" onerror="this.style.display='none'" />
                    <div class="brand-mark">
                        <span class="brand-title">TrackFinder</span>
                        <span class="brand-subtitle">Track discovery platform</span>
                    </div>
                </a>
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav align-items-lg-center ms-lg-4 me-auto gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Assessment" asp-action="Index">Assessment</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Assessment" asp-action="History">History</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="tf-main pb-5">
        <div class="container-xxl">
            @RenderBody()
        </div>
    </main>

    <footer class="tf-footer py-4 mt-5">
        <div class="container-xxl">
            <div class="row align-items-center g-3">
                <div class="col-md-6">
                    <div class="d-flex align-items-center gap-3">
                        <img src="~/images/logo.png" alt="TrackFinder logo" class="footer-logo" onerror="this.style.display='none'" />
                        <div>
                            <div class="fw-bold text-brand-ink">TrackFinder</div>
                            <div class="small text-brand-muted">Assessment and recommendation platform</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 text-md-end">
                    <div class="small text-brand-muted">
                        &copy; @DateTime.UtcNow.Year TrackFinder. All rights reserved.
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>window.jQuery || document.write('<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"><\/script>');</script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>window.bootstrap || document.write('<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"><\/script>');</script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
