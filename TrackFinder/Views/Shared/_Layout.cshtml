@using Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TrackFinder</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" id="bootstrap-css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        html, body {
            margin: 0;
            padding: 0;
        }

        .tf-header,
        .tf-navbar-fixed {
            margin-top: 0 !important;
            top: 0 !important;
        }

        .navbar-toggle {
            display: none;
            background: none;
            border: none;
            padding: 8px;
            cursor: pointer;
            color: rgba(255,255,255,0.75);
            font-size: 22px;
            transition: opacity 0.2s;
            border-radius: 8px;
        }
        .navbar-toggle:hover {
            opacity: 1;
            background: rgba(255,255,255,0.1);
        }

        .navbar-links {
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .navbar-link {
            font-size: 15px;
            font-weight: 500;
            color: rgba(255,255,255,0.8);
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 8px;
            transition: background 0.2s, color 0.2s;
            position: relative;
        }
        .navbar-link:hover {
            background: rgba(255,255,255,0.1);
            color: #fff;
        }

        @@media (max-width: 991.98px) {
            .navbar-toggle {
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .navbar-links {
                display: none;
                position: absolute;
                top: 100%;
                left: 0;
                right: 0;
                background: rgba(15, 23, 42, 0.97);
                backdrop-filter: blur(12px);
                border-bottom: 1px solid rgba(255,255,255,0.08);
                flex-direction: column;
                padding: 12px 24px;
                gap: 4px;
                box-shadow: 0 8px 24px rgba(0,0,0,0.3);
                z-index: 99;
            }
            .navbar-links.open {
                display: flex;
            }
            .navbar-link {
                padding: 12px 16px;
                width: 100%;
                color: rgba(255,255,255,0.7);
            }
            .navbar-link:hover {
                background: rgba(255,255,255,0.08);
                color: #fff;
            }
        }
    </style>
    <script>
        (function () {
            window.addEventListener("DOMContentLoaded", function () {
                var el = document.createElement("div");
                el.className = "d-none";
                document.body.appendChild(el);
                var loaded = getComputedStyle(el).display === "none";
                document.body.removeChild(el);
                if (!loaded) {
                    console.warn("[TrackFinder] Local Bootstrap CSS failed to load (check wwwroot/lib/bootstrap). Falling back to CDN.");
                    var link = document.createElement("link");
                    link.rel = "stylesheet";
                    link.href = "https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css";
                    document.head.appendChild(link);
                }
            });
        })();
    </script>
</head>
<body class="tf-app">
    <header class="tf-header">
        <nav class="tf-navbar tf-navbar-fixed py-3">
            <div class="container-xxl d-flex align-items-center justify-content-between">
                <a class="navbar-brand d-flex align-items-center gap-3 m-0" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.png" alt="TrackFinder logo" class="navbar-logo" onerror="this.style.display='none'" />
                    <div class="brand-mark">
                        <span class="brand-title">TrackFinder</span>
                        <span class="brand-subtitle">Track discovery platform</span>
                    </div>
                </a>
                <button class="navbar-toggle" id="navbarToggle" type="button" aria-label="Toggle navigation">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
                </button>
            </div>
            <div class="navbar-links" id="navbarLinks">
                <a class="navbar-link" asp-controller="Home" asp-action="Index">Home</a>
                <a class="navbar-link" asp-controller="Assessment" asp-action="Index">Assessment</a>
                <a class="navbar-link" asp-controller="Assessment" asp-action="History">History</a>
                <a class="navbar-link" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </nav>
    </header>

    <main role="main" class="tf-main pb-5">
        <div class="container-xxl">
            @RenderBody()
        </div>
    </main>

    <footer class="tf-footer py-4 mt-5">
        <div class="container-xxl">
            <div class="row align-items-center g-3">
                <div class="col-md-6">
                    <div class="d-flex align-items-center gap-3">
                        <img src="~/images/logo.png" alt="TrackFinder logo" class="footer-logo" onerror="this.style.display='none'" />
                        <div>
                            <div class="fw-bold text-brand-ink">TrackFinder</div>
                            <div class="small text-brand-muted">Assessment and recommendation platform</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 text-md-end">
                    <div class="small text-brand-muted">
                        &copy; @DateTime.UtcNow.Year TrackFinder. All rights reserved.
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>window.jQuery || document.write('<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"><\/script>');</script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>window.bootstrap || document.write('<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"><\/script>');</script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function() {
            var toggle = document.getElementById('navbarToggle');
            var links = document.getElementById('navbarLinks');
            if (toggle && links) {
                toggle.addEventListener('click', function(e) {
                    e.stopPropagation();
                    links.classList.toggle('open');
                });
                document.addEventListener('click', function(e) {
                    if (!links.contains(e.target) && e.target !== toggle) {
                        links.classList.remove('open');
                    }
                });
            }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
