<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Track Finder Portal</title>
    <link rel="icon" type="image/png" href="~/images/Logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --primary:             #006191;
            --primary-light:       #1f95d8;
            --primary-dark:        #004b71;
            --secondary:           #0b1c30;
            --surface:             #ffffff;
            --bg:                  #f3f8fc;
            --text:                #334155;
            --text-muted:          #64748b;
            --border:              #e2e8f0;
            --radius-sm:           8px;
            --radius-md:           12px;
            --radius-lg:           20px;
            --shadow-sm:           0 1px 2px rgba(0,0,0,0.05);
            --shadow-md:           0 4px 12px rgba(13,43,68,0.05), 0 1px 3px rgba(13,43,68,0.03);
            --shadow-lg:           0 10px 25px rgba(13,43,68,0.08), 0 3px 6px rgba(13,43,68,0.04);
            --transition:          all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            font-family: 'Hanken Grotesk', 'Segoe UI', sans-serif;
            background-color: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        /* ── Sticky Glass Navbar ─────────────────────────────────── */
        .navbar {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(226, 232, 240, 0.8);
            padding: 14px 0;
            transition: var(--transition);
        }

        .navbar-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 20px;
            font-weight: 700;
            color: var(--primary);
        }

        .navbar-logo {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            object-fit: cover;
        }

        .navbar-links {
            display: flex;
            align-items: center;
            gap: 28px;
        }

        .navbar-link {
            font-size: 15px;
            font-weight: 550;
            color: var(--text-muted);
            position: relative;
            padding: 6px 0;
            transition: var(--transition);
        }

        .navbar-link:hover, .navbar-link.active {
            color: var(--primary);
        }

        .navbar-link.active::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 2px;
            background-color: var(--primary);
            border-radius: 2px;
        }

        .navbar-actions {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        /* User Profile Dropdown */
        .profile-dropdown-container {
            position: relative;
        }

        .avatar-btn {
            background: none;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 4px;
            border-radius: 999px;
            transition: var(--transition);
        }

        .avatar-btn:hover {
            background: rgba(0, 97, 145, 0.06);
        }

        .avatar-image {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--primary);
        }

        .avatar-placeholder {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: var(--primary);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 15px;
            border: 2px solid var(--primary);
        }

        .profile-dropdown-container .dropdown-menu {
            position: absolute;
            right: 0;
            top: 50px;
            width: 240px;
            background: var(--surface);
            border-radius: var(--radius-md);
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--border);
            padding: 8px;
            display: none;
            flex-direction: column;
            gap: 4px;
            animation: slideDown 0.2s ease-out;
        }

        .profile-dropdown-container .dropdown-menu.show {
            display: flex;
        }

        @@keyframes slideDown {
            from { opacity: 0; transform: translateY(-8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .profile-dropdown-container .dropdown-header {
            padding: 12px 16px;
            border-bottom: 1px solid var(--border);
            margin-bottom: 6px;
        }

        .profile-dropdown-container .dropdown-user-name {
            font-weight: 700;
            font-size: 15px;
            color: var(--secondary);
        }

        .profile-dropdown-container .dropdown-user-role {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .profile-dropdown-container .dropdown-item {
            padding: 10px 16px;
            border-radius: var(--radius-sm);
            font-size: 14px;
            font-weight: 500;
            color: var(--text);
            display: flex;
            align-items: center;
            gap: 10px;
            transition: var(--transition);
            width: 100%;
            text-align: left;
            background: none;
            border: none;
            cursor: pointer;
        }

        .profile-dropdown-container .dropdown-item:hover {
            background-color: var(--bg);
            color: var(--primary);
        }

        .dropdown-divider {
            height: 1px;
            background: var(--border);
            margin: 6px 0;
        }

        /* ── Page Layout ─────────────────────────────────────────── */
        main {
            flex: 1;
            max-width: 1200px;
            width: 100%;
            margin: 0 auto;
            padding: 40px 24px;
        }

        /* ── Footer ──────────────────────────────────────────────── */
        footer {
            background: var(--secondary);
            color: #cbd5e1;
            padding: 32px 0;
            margin-top: auto;
            border-top: 1px solid rgba(255,255,255,0.05);
        }

        .footer-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 14px;
        }

        .footer-logo {
            font-weight: 700;
            color: white;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .footer-logo-img {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            object-fit: cover;
        }

        /* ── Toasts ──────────────────────────────────────────────── */
        .toast-container {
            position: fixed;
            top: 85px;
            right: 24px;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            gap: 12px;
            max-width: 380px;
            width: 100%;
        }

        .toast-alert {
            background: white;
            border-radius: var(--radius-md);
            box-shadow: var(--shadow-lg);
            padding: 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-left: 4px solid var(--primary);
            animation: slideIn 0.3s ease-out;
        }

        .toast-alert.success {
            border-left-color: #10b981;
        }

        .toast-alert.error {
            border-left-color: #ef4444;
        }

        @@keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        .toast-message {
            font-size: 14px;
            font-weight: 550;
            color: var(--secondary);
        }

        .navbar-toggle {
            display: none;
            background: none;
            border: none;
            padding: 8px;
            cursor: pointer;
            color: var(--text-muted);
            font-size: 22px;
            transition: var(--transition);
            border-radius: 8px;
        }
        .navbar-toggle:hover {
            background: var(--bg);
            color: var(--primary);
        }
        @@media (max-width: 991.98px) {
            .navbar-toggle {
                display: flex;
                align-items: center;
                justify-content: center;
            }
            .navbar-links {
                display: none;
                position: absolute;
                top: 100%;
                left: 0;
                right: 0;
                background: rgba(255, 255, 255, 0.98);
                backdrop-filter: blur(12px);
                border-bottom: 1px solid var(--border);
                flex-direction: column;
                padding: 12px 24px;
                gap: 4px;
                box-shadow: var(--shadow-md);
                z-index: 99;
            }
            .navbar-links.open {
                display: flex;
            }
            .navbar-links .navbar-link {
                padding: 12px 16px;
                border-radius: var(--radius-sm);
                width: 100%;
            }
            .navbar-links .navbar-link:hover {
                background: var(--bg);
            }
            .navbar-links .navbar-link.active::after {
                display: none;
            }
            .navbar-links .navbar-link.active {
                background: rgba(0, 97, 145, 0.08);
                color: var(--primary);
            }
            .navbar-container {
                flex-wrap: wrap;
                padding: 0 16px;
            }
            .navbar-actions {
                margin-left: auto;
            }
            main {
                padding: 24px 16px !important;
            }
        }

        /* Bootstrap-collapse support (no Bootstrap CSS) */
        .collapse:not(.show) { display: none; }
        .collapsing {
            height: 0;
            overflow: hidden;
            transition: height 0.35s ease;
        }
    </style>
</head>
<body>

    <!-- Toast Alerts -->
    <div class="toast-container">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="toast-alert success">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2.5">
                    <polyline points="20 6 9 17 4 12"/>
                </svg>
                <div class="toast-message">@TempData["SuccessMessage"]</div>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="toast-alert error">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5">
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <div class="toast-message">@TempData["ErrorMessage"]</div>
            </div>
        }
    </div>

    <!-- ── Navbar ────────────────────────────────────────── -->
    <nav class="navbar">
        <div class="navbar-container">
            <a class="navbar-brand" href="/Main">
                <img src="~/images/Logo.png" alt="Track Finder" class="navbar-logo" onerror="this.style.display='none'" />
                <span>Track Finder</span>
            </a>

            <button class="navbar-toggle" id="navbarToggle" aria-label="Toggle navigation">
                <i class="fas fa-bars"></i>
            </button>
            <div class="navbar-links" id="navbarLinks">
                <a href="/Main" class="navbar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Main" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">Dashboard</a>
                <a href="@(User.IsInRole("Instructor") ? "/CourseCreation" : "/CourseSales")" class="navbar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() is "CourseCreation" or "CourseSales" ? "active" : "")">Courses</a>
                <a href="/Community" class="navbar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Community" ? "active" : "")">Community</a>
                <a href="/Assessment" class="navbar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Assessment" ? "active" : "")">Assessment</a>
                <a href="/Achievement" class="navbar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Achievement" ? "active" : "")">Achievements</a>
                <a href="/Main/Profile" class="navbar-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Profile" ? "active" : "")">Profile Settings</a>
            </div>

            <div class="navbar-actions">
                <div class="profile-dropdown-container">
                    <button class="avatar-btn" id="avatarBtn">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var claimUser = User.Identity.Name ?? "U";
                            var firstChar = claimUser.Substring(0, 1).ToUpper();

                            // In ASP.NET MVC, we can try to retrieve ProfilePictureUrl from database but since layout is general, we look for ViewBag.ProfilePictureUrl
                            var profilePic = ViewBag.ProfilePictureUrl as string;
                            if (!string.IsNullOrEmpty(profilePic))
                            {
                                <img src="@profilePic" alt="Avatar" class="avatar-image" />
                            }
                            else
                            {
                                <div class="avatar-placeholder">@firstChar</div>
                            }
                        }
                    </button>
                    
                    <div class="dropdown-menu" id="dropdownMenu">
                        <div class="dropdown-header">
                            <div class="dropdown-user-name">@User.Identity?.Name</div>
                            <div class="dropdown-user-role">
                                @(User.IsInRole("Instructor") ? "Instructor Portal" : "Student Portal")
                            </div>
                        </div>
                        <a href="/Main/Profile" class="dropdown-item">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                            </svg>
                            Edit Profile
                        </a>
                        <div class="dropdown-divider"></div>
                        <form asp-controller="Login" asp-action="Logout" method="post" id="logoutForm">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dropdown-item" style="color: #ef4444;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                                </svg>
                                Sign Out
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- ── Main Content ──────────────────────────────────── -->
    <main>
        @RenderBody()
    </main>

    <!-- ── Footer ────────────────────────────────────────── -->
    <footer>
        <div class="footer-container">
            <span class="footer-logo">
                <img src="~/images/Logo.png" alt="Track Finder" class="footer-logo-img" onerror="this.style.display='none'" />
                Track Finder
            </span>
            <span>&copy; @DateTime.Now.Year. All rights reserved.</span>
        </div>
    </footer>

    <!-- Bootstrap JS (components only, no CSS conflicts) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Responsive & Dropdown Script -->
    <script>
        // Navbar toggle for mobile
        (function() {
            const toggle = document.getElementById('navbarToggle');
            const links = document.getElementById('navbarLinks');
            if (toggle && links) {
                toggle.addEventListener('click', function(e) {
                    e.stopPropagation();
                    links.classList.toggle('open');
                });
                document.addEventListener('click', function(e) {
                    if (!links.contains(e.target) && e.target !== toggle) {
                        links.classList.remove('open');
                    }
                });
            }
        })();

        const btn = document.getElementById('avatarBtn');
        const menu = document.getElementById('dropdownMenu');
        
        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            menu.classList.toggle('show');
        });

        document.addEventListener('click', (e) => {
            if (!menu.contains(e.target) && e.target !== btn) {
                menu.classList.remove('show');
            }
        });

        // Autoclose toasts after 5 seconds
        const toasts = document.querySelectorAll('.toast-alert');
        toasts.forEach(t => {
            setTimeout(() => {
                t.style.transition = 'opacity 0.5s ease-out, transform 0.5s ease-out';
                t.style.opacity = '0';
                t.style.transform = 'translateY(-20px)';
                setTimeout(() => t.remove(), 500);
            }, 5000);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
