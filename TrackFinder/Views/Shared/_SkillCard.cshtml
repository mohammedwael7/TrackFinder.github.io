@model GainedSkillVM

<article class="skill-card card h-100 border-0 rounded-4">
    <div class="card-body p-4">
        <div class="d-flex align-items-start gap-3">
            <span class="skill-icon">SK</span>
            <div>
                <h3 class="h6 text-brand-ink mb-2">@Model.Name</h3>
                <p class="text-brand-muted small mb-0">@Model.Description</p>
            </div>
        </div>
    </div>
</article>
